);\nconst dir = variables.profile_pic_folder || '';\ntry {\n  const files = fs.readdirSync(dir).filter(f => /\\.(jpg|jpeg|png)$/i.test(f));\n  if (files.length > 0) { variables.profile_pic_file = path.join(dir, files[0]); console.log('Profile pic: ' + files[0]); }\n  else { console.log('No profile pic found'); }\n} catch(e) { console.log('Error reading profile folder: ' + e.message); }", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}}, {"id": "jscov", "type": "BlockBasicWithFallback", "label": "javascript-code", "initialized": false, "position": {"x": 750, "y": 150}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "เลือกรูปปก", "timeout": "10000", "context": "website", "code": "const fs = require('fs');\nconst path = require('path');\nconst dir = variables.cover_pic_folder || '';\ntry {\n  const files = fs.readdirSync(dir).filter(f => /\\.(jpg|jpeg|png)$/i.test(f));\n  if (files.length > 0) { variables.cover_pic_file = path.join(dir, files[0]); console.log('Cover pic: ' + files[0]); }\n  else { console.log('No cover pic found'); }\n} catch(e) { console.log('Error reading cover folder: ' + e.message); }", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}}, {"id": "openfb", "type": "BlockBasicWithFallback", "label": "open-url", "initialized": false, "position": {"x": 1050, "y": 150}, "data": {"icon": "riLink", "disableBlock": false, "url": "https://www.facebook.com/profile", "userAgent": "", "description": "เปิด Facebook", "waitTabLoaded": true, "customUserAgent": false, "newTab": false, "active": true, "delay": 2000}}, {"id": "nprof", "type": "BlockNote", "label": "note", "initialized": false, "position": {"x": 100, "y": 320}, "data": {"icon": "riFileEditLine", "note": "เปลี่ยนรูปโปรไฟล์", "drawing": false, "width": 200, "height": 30, "color": "green", "fontSize": "large", "disableBlock": false}}, {"id": "clkpic", "type": "BlockBasicWithFallback", "label": "event-click", "initia