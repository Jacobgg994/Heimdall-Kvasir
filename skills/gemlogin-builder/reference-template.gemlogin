{"extVersion":2,"name":"Cookie login","icon":"riGlobalLine","table":[],"version":"1.0.0","drawflow":{"nodes":[{"id":"QiLiQbJeesOD6CVmYWlVP","type":"BlockBasic","initialized":false,"position":{"x":-315,"y":300},"data":{"icon":"riPlayLine","disableBlock":false,"description":"","type":"manual","interval":60,"delay":5,"date":"","time":"00:00","url":"","shortcut":"","activeInInput":false,"isUrlRegex":false,"days":[],"contextMenuName":"","contextTypes":[],"parameters":[{"name":"platform_1","label":"Facebook","type":"checkbox","description":"","defaultValue":true,"placeholder":"Facebook","data":true,"id":"Fi78"},{"name":"platform_2","label":"X","type":"checkbox","description":"","defaultValue":false,"placeholder":"Twitter","data":true,"id":"p_aR"},{"name":"platform_3","label":"TikTok","type":"checkbox","description":"เลือกอันไหนอันหนึ่ง","defaultValue":false,"placeholder":"TikTok","data":true,"id":"CG7H"}],"preferParamsInTab":false,"observeElement":{"selector":"","baseSelector":"","matchPattern":"","targetOptions":{"subtree":false,"childList":true,"attributes":false,"attributeFilter":[],"characterData":false},"baseElOptions":{"subtree":false,"childList":true,"attributes":false,"attributeFilter":[],"characterData":false}}},"label":"trigger"},{"id":"rleyaw7","type":"BlockBasicWithFallback","initialized":false,"position":{"x":765,"y":345},"data":{"icon":"mdiCookieOutline","disableBlock":false,"description":"","type":"set","jsonCode":"{{variables.formatted}}","useJson":false,"getAll":false,"typeData":"json","domain":"www.x.com","expirationDate":"","path":"","sameSite":"","name":"","url":"","value":"{{variables.resource.Twitter.Cookie}}","httpOnly":false,"secure":false,"session":false,"assignVariable":false,"variableName":"","saveData":true,"dataColumn":"","delay":0},"label":"cookie"},{"id":"j33uk2p","type":"BlockBasicWithFallback","initialized":false,"position":{"x":450,"y":390},"data":{"icon":"riCodeSSlashLine","disableBlock":false,"description":"X","timeout":"20000","context":"website","code":"(function () {\n  // ===== ดึงค่า Cookie String จาก variables.resource.Twitter.Cookie =====\n  let srcRaw;\n  try {\n    if (typeof RefData === 'function') {\n      srcRaw = RefData('variables', 'resource.Twitter.Cookie');\n    }\n  } catch (e) {\n    console.log('[Error] Error getting cookie string:', e);\n    srcRaw = '';\n  }\n  \n  if (srcRaw == null || srcRaw === undefined) {\n    srcRaw = '';\n  }\n  \n  let cookieString = (typeof srcRaw === 'string') ? srcRaw : JSON.stringify(srcRaw);\n  \n  console.log('[Info] Raw cookie string length:', cookieString.length);\n  \n  if (!cookieString || cookieString.trim() === '' || cookieString === '{}' || cookieString === 'null') {\n    console.log('[Error] No cookie string found in variables.resource.Twitter.Cookie');\n    return '';\n  }\n  \n  // ===== ตั้งค่า Domain =====\n  let domain = '.x.com';\n  console.log('[Info] Using domain:', domain);\n  \n  // ===== Function แปลง Cookie String (รองรับหลายรูปแบบ) =====\n  function parseCookies(cookieStr, cookieDomain) {\n    // ลบ whitespace ที่ไม่จำเป็นที่หน้าและหลัง\n    cookieStr = cookieStr.trim();\n    \n    // แยก cookies ด้วย semicolon\n    let cookies = cookieStr.split(';');\n    let result = [];\n    \n    for (let i = 0; i < cookies.length; i++) {\n      let cookie = cookies[i].trim();\n      if (!cookie) continue;\n      \n      // หา index ของ = ตัวแรก\n      let equalIndex = cookie.indexOf('=');\n      if (equalIndex === -1) continue;\n      \n      let name = cookie.substring(0, equalIndex).trim();\n      let value = cookie.substring(equalIndex + 1).trim();\n      \n      // ลบ quotes ที่ไม่จำเป็น (ถ้ามี)\n      if (value.charAt(0) === '\"' && value.charAt(value.length - 1) === '\"') {\n        value = value.substring(1, value.length - 1);\n      }\n      \n      // กำหนด secure และ httpOnly\n      let secure = true;\n      let httpOnly = false;\n      \n      // Auth cookies ที่สำคัญ\n      if (name === 'auth_token' || name === 'att' || name === 'kdt' || name === '_twitter_sess') {\n        httpOnly = true;\n        secure = true;\n      }\n      \n      // CSRF token\n      if (name === 'ct0') {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // Guest และ tracking cookies\n      if (name.indexOf('guest') !== -1 || name === 'lang' || \n          name === 'personalization_id' || name.indexOf('g_state') !== -1 ||\n          name.indexOf('__cf') !== -1 || name === 'dnt' || name === 'cf_clearance') {\n        secure = false;\n        httpOnly = false;\n      }\n      \n      // Twitter ID และ GT token\n      if (name === 'twid' || name === 'gt') {\n        secure = true;\n        httpOnly = false;\n      }\n      \n      // __cuid cookie\n      if (name === '__cuid') {\n        secure = true;\n        httpOnly = true;\n      }\n      \n      result.push({\n        name: name,\n        value: value,\n        domain: cookieDomain,\n        path: '/',\n        secure: secure,\n        httpOnly: httpOnly\n      });\n    }\n    \n    return result;\n  }\n  \n  // ===== แปลง Cookie String =====\n  let formatted;\n  try {\n    let cookiesArray = parseCookies(cookieString, domain);\n    \n    if (cookiesArray.length === 0) {\n      console.log('[Error] No cookies parsed. Check cookie string format.');\n      console.log('[Debug] Cookie string preview:', cookieString.substring(0, 100));\n      return '';\n    }\n    \n    formatted = JSON.stringify(cookiesArray);\n    \n    console.log('[Success] Formatted cookies count:', cookiesArray.length);\n    console.log('[Success] Cookie names:', cookiesArray.map(function(c) { return c.name; }).join(', '));\n    \n    // แสดงข้อมูล cookies สำคัญที่พบ\n    let authCookies = ['auth_token', 'ct0', 'twid', '_twitter_sess'];\n    let foundAuth = [];\n    for (let i = 0; i < cookiesArray.length; i++) {\n      if (authCookies.indexOf(cookiesArray[i].name) !== -1) {\n        foundAuth.push(cookiesArray[i].name);\n      }\n    }\n    if (foundAuth.length > 0) {\n      console.log('[Info] Important auth cookies found:', foundAuth.join(', '));\n    }\n    \n  } catch (e) {\n    console.log('[Error] Error parsing cookies:', e);\n    return '';\n  }\n  \n  // ===== บันทึกข้อมูล =====\n  try {\n    if (typeof SetVariable === 'function') {\n      SetVariable('formatted', formatted);\n      console.log('[Success] Data saved to \"formatted\" variable');\n    }\n  } catch (e) {\n    console.log('[Error] Error setting variable:', e);\n  }\n  \n  return formatted;\n})();","preloadScripts":[],"everyNewTab":false,"runBeforeLoad":false,"delay":0,"$breakpoint":false},"label":"javascript-code"},{"id":"thysyq8","type":"BlockBasicWithFallback","initialized":false,"position":{"x":1455,"y":495},"data":{"icon":"riLink","disableBlock":false,"url":"https://x.com/","userAgent":"","description":"เปิดเว็บ","waitTabLoaded":false,"customUserAgent":false,"newTab":false,"active":true,"delay":"1000"},"label":"open-url"},{"id":"oozcfrz","type":"BlockBasic","initialized":false,"position":{"x":1830,"y":390},"data":{"icon":"riFlagLine"},"label":"end"},{"id":"lticdrf","type":"BlockBasicWithFallback","initialized":false,"position":{"x":450,"y":300},"data":{"icon":"riCodeSSlashLine","disableBlock":false,"description":"Facebook","timeout":"20000","context":"website","code":"(function () {\n  // ===== ดึงค่า Cookie String จาก variables.resource.Facebook.Cookie =====\n  let srcRaw;\n  try {\n    if (typeof RefData === 'function') {\n      srcRaw = RefData('variables', 'resource.Facebook.Cookie');\n    }\n  } catch (e) {\n    console.log('[Error] Error getting cookie string:', e);\n    srcRaw = '';\n  }\n  \n  if (srcRaw == null || srcRaw === undefined) {\n    srcRaw = '';\n  }\n  \n  let cookieString = (typeof srcRaw === 'string') ? srcRaw : JSON.stringify(srcRaw);\n  \n  console.log('[Info] Raw cookie string length:', cookieString.length);\n  \n  if (!cookieString || cookieString.trim() === '' || cookieString === '{}' || cookieString === 'null') {\n    console.log('[Error] No cookie string found in variables.resource.Facebook.Cookie');\n    return '';\n  }\n  \n  // ===== ตั้งค่า Domain สำหรับ Facebook =====\n  let domain = '.facebook.com';\n  console.log('[Info] Using domain:', domain);\n  \n  // ===== Function แปลง Cookie String (รองรับหลายรูปแบบ) =====\n  function parseCookies(cookieStr, cookieDomain) {\n    // ลบ whitespace ที่ไม่จำเป็นที่หน้าและหลัง\n    cookieStr = cookieStr.trim();\n    \n    // แยก cookies ด้วย semicolon\n    let cookies = cookieStr.split(';');\n    let result = [];\n    \n    for (let i = 0; i < cookies.length; i++) {\n      let cookie = cookies[i].trim();\n      if (!cookie) continue;\n      \n      // หา index ของ = ตัวแรก\n      let equalIndex = cookie.indexOf('=');\n      if (equalIndex === -1) continue;\n      \n      let name = cookie.substring(0, equalIndex).trim();\n      let value = cookie.substring(equalIndex + 1).trim();\n      \n      // ลบ quotes ที่ไม่จำเป็น (ถ้ามี)\n      if (value.charAt(0) === '\"' && value.charAt(value.length - 1) === '\"') {\n        value = value.substring(1, value.length - 1);\n      }\n      \n      // กำหนด secure และ httpOnly สำหรับ Facebook cookies\n      let secure = true;\n      let httpOnly = false;\n      \n      // Facebook auth cookies ที่สำคัญ\n      if (name === 'c_user' || name === 'xs' || name === 'sb' || name === 'datr') {\n        httpOnly = true;\n        secure = true;\n      }\n      \n      // Facebook session และ tracking\n      if (name === 'fr' || name === 'presence' || name === 'wd' || \n          name === 'dpr' || name === 'm_pixel_ratio') {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // Facebook CSRF และ security\n      if (name === 'spin' || name === 'locale') {\n        httpOnly = false;\n        secure = false;\n      }\n      \n      // Cloudflare และ tracking cookies\n      if (name.indexOf('__cf') !== -1 || name.indexOf('_fb') !== -1 || \n          name === 'dnt' || name.indexOf('cf_clearance') !== -1) {\n        secure = false;\n        httpOnly = false;\n      }\n      \n      result.push({\n        name: name,\n        value: value,\n        domain: cookieDomain,\n        path: '/',\n        secure: secure,\n        httpOnly: httpOnly\n      });\n    }\n    \n    return result;\n  }\n  \n  // ===== แปลง Cookie String =====\n  let formatted;\n  try {\n    let cookiesArray = parseCookies(cookieString, domain);\n    \n    if (cookiesArray.length === 0) {\n      console.log('[Error] No cookies parsed. Check cookie string format.');\n      console.log('[Debug] Cookie string preview:', cookieString.substring(0, 100));\n      return '';\n    }\n    \n    formatted = JSON.stringify(cookiesArray);\n    \n    console.log('[Success] Formatted cookies count:', cookiesArray.length);\n    console.log('[Success] Cookie names:', cookiesArray.map(function(c) { return c.name; }).join(', '));\n    \n    // แสดงข้อมูล cookies สำคัญที่พบ\n    let authCookies = ['c_user', 'xs', 'datr', 'sb', 'fr'];\n    let foundAuth = [];\n    for (let i = 0; i < cookiesArray.length; i++) {\n      if (authCookies.indexOf(cookiesArray[i].name) !== -1) {\n        foundAuth.push(cookiesArray[i].name);\n      }\n    }\n    if (foundAuth.length > 0) {\n      console.log('[Info] Important Facebook cookies found:', foundAuth.join(', '));\n    }\n    \n  } catch (e) {\n    console.log('[Error] Error parsing cookies:', e);\n    return '';\n  }\n  \n  // ===== บันทึกข้อมูล =====\n  try {\n    if (typeof SetVariable === 'function') {\n      SetVariable('formatted', formatted);\n      console.log('[Success] Data saved to \"formatted\" variable');\n    }\n  } catch (e) {\n    console.log('[Error] Error setting variable:', e);\n  }\n  \n  return formatted;\n})();","preloadScripts":[],"everyNewTab":false,"runBeforeLoad":false,"delay":0,"$breakpoint":false},"label":"javascript-code","blockId":"lticdrf"},{"id":"z60aigw","type":"BlockConditions","initialized":false,"position":{"x":45,"y":270},"data":{"icon":"riAB","description":"","disableBlock":false,"conditions":[{"id":"e7D-FtGls2oZW3WhvpGVn","name":"Facebook","conditions":[{"id":"tcxYPWQWhPB6L-H9Qxmai","conditions":[{"id":"sIH3BMWr8wQ3eyRExZYJC","items":[{"type":"value","category":"value","data":{"value":"{{variables.platform_1}}"},"id":"l90yypY0R-gU9jZHKWJq_"},{"category":"compare","type":"itr","id":"hGPpxlioX-sMctd_FyToj"}]}]}]},{"id":"qYxSAzAWdMsMgCXbGZY92","name":"Twitter","conditions":[{"id":"WCQtDUK9h0FM3HtTncjuE","conditions":[{"id":"sebV05mP3KD1HGSmmrS8B","items":[{"type":"value","category":"value","data":{"value":"{{variables.platform_2}}"},"id":"ksv4NO9OA1cmcdc8q_bYS"},{"category":"compare","type":"itr","id":"kxsNU1ZCkHqSOaWlW37CV"}]}]}]},{"id":"airbgSietiwd9jXt_AIOQ","name":"TikTok","conditions":[{"id":"eXA2OFr7Ft9A7E2rKWA0V","conditions":[{"id":"3K9lWhgXUIxl9tFC0TKMo","items":[{"type":"value","category":"value","data":{"value":"{{variables.platform_3}}"},"id":"FPbQyWP8Do-auV2x-YZdQ"},{"category":"compare","type":"itr","id":"TiJCnHwqklfno2PN_e6dU"}]}]}]}],"retryConditions":false,"retryCount":10,"retryTimeout":1000,"delay":0},"label":"conditions"},{"id":"zpbz2n6","type":"BlockBasic","initialized":false,"position":{"x":360,"y":735},"data":{"icon":"riFlagLine"},"label":"end"},{"id":"29dfo1h","type":"BlockNote","initialized":false,"position":{"x":435,"y":-75},"data":{"icon":"riFileEditLine","disableBlock":false,"note":"ตั้งค่าให้ Save Cookie หลังปิดด้วย","drawing":false,"width":419,"height":124,"color":"white","fontSize":"extra-large"},"label":"note"},{"id":"n577xr5","type":"BlockBasicWithFallback","initialized":false,"position":{"x":1455,"y":300},"data":{"icon":"riLink","disableBlock":false,"url":"https://www.facebook.com/","userAgent":"","description":"เปิดเว็บ","waitTabLoaded":false,"customUserAgent":false,"newTab":false,"active":true,"delay":"1000"},"label":"open-url","blockId":"n577xr5"},{"id":"jwyw5xf","type":"BlockBasicWithFallback","initialized":false,"position":{"x":450,"y":480},"data":{"icon":"riCodeSSlashLine","disableBlock":false,"description":"TikTok","timeout":"20000","context":"website","code":"(function () {\n  // ===== ดึงค่า Cookie String จาก variables.resource.Tiktok.Cookie =====\n  let srcRaw;\n  let cookieString = '';\n  \n  try {\n    if (typeof RefData === 'function') {\n      // ลองหลายวิธีในการเข้าถึง\n      console.log('[Debug] Trying to get Tiktok cookie...');\n      \n      // วิธีที่ 1: ดึง resource object ทั้งหมดแล้วเข้าถึง Tiktok.Cookie\n      try {\n        let resource = RefData('variables', 'resource');\n        console.log('[Debug] Resource type:', typeof resource);\n        if (resource && resource.Tiktok && resource.Tiktok.Cookie) {\n          srcRaw = resource.Tiktok.Cookie;\n          console.log('[Debug] Got cookie from resource.Tiktok.Cookie');\n        }\n      } catch (e) {\n        console.log('[Debug] Method 1 failed:', e);\n      }\n      \n      // วิธีที่ 2: ลองแบบ dot notation string\n      if (!srcRaw) {\n        try {\n          srcRaw = RefData('variables', 'resource.Tiktok.Cookie');\n          console.log('[Debug] Got cookie from resource.Tiktok.Cookie (string path)');\n        } catch (e) {\n          console.log('[Debug] Method 2 failed:', e);\n        }\n      }\n      \n      // วิธีที่ 3: ลองชื่อตัวแปรตรงๆ\n      if (!srcRaw) {\n        try {\n          srcRaw = RefData('variables', 'Tiktok_Cookie');\n          console.log('[Debug] Got cookie from Tiktok_Cookie');\n        } catch (e) {\n          console.log('[Debug] Method 3 failed:', e);\n        }\n      }\n    }\n  } catch (e) {\n    console.log('[Error] Error getting cookie string:', e);\n  }\n  \n  if (srcRaw == null || srcRaw === undefined) {\n    srcRaw = '';\n  }\n  \n  cookieString = (typeof srcRaw === 'string') ? srcRaw : JSON.stringify(srcRaw);\n  \n  console.log('[Info] Raw cookie string length:', cookieString.length);\n  \n  if (!cookieString || cookieString.trim() === '' || cookieString === '{}' || cookieString === 'null') {\n    console.log('[Error] No cookie string found.');\n    console.log('[Error] Please check that variables.resource.Tiktok.Cookie exists and has a value');\n    return '';\n  }\n  \n  // ===== ตั้งค่า Domain สำหรับ TikTok =====\n  let domain = '.tiktok.com';\n  console.log('[Info] Using domain:', domain);\n  \n  // ===== Function แปลง Cookie String (รองรับหลายรูปแบบ) =====\n  function parseCookies(cookieStr, cookieDomain) {\n    // ลบ whitespace ที่ไม่จำเป็นที่หน้าและหลัง\n    cookieStr = cookieStr.trim();\n    \n    // แยก cookies ด้วย semicolon\n    let cookies = cookieStr.split(';');\n    let result = [];\n    \n    for (let i = 0; i < cookies.length; i++) {\n      let cookie = cookies[i].trim();\n      if (!cookie) continue;\n      \n      // หา index ของ = ตัวแรก\n      let equalIndex = cookie.indexOf('=');\n      if (equalIndex === -1) continue;\n      \n      let name = cookie.substring(0, equalIndex).trim();\n      let value = cookie.substring(equalIndex + 1).trim();\n      \n      // ลบ quotes ที่ไม่จำเป็น (ถ้ามี)\n      if (value.charAt(0) === '\"' && value.charAt(value.length - 1) === '\"') {\n        value = value.substring(1, value.length - 1);\n      }\n      \n      // กำหนด secure และ httpOnly สำหรับ TikTok cookies\n      let secure = true;\n      let httpOnly = false;\n      \n      // TikTok session cookies ที่สำคัญมาก (httpOnly: true)\n      if (name === 'sessionid' || name === 'sessionid_ss' || \n          name === 'sid_guard' || name === 'sid_tt' ||\n          name === 'sid_ucp_v1' || name === 'ssid_ucp_v1') {\n        httpOnly = true;\n        secure = true;\n      }\n      \n      // TikTok user ID cookies\n      if (name === 'uid_tt' || name === 'uid_tt_ss' || \n          name === 'living_user_id' || name === 'multi_sids') {\n        httpOnly = true;\n        secure = true;\n      }\n      \n      // TikTok tracking และ device cookies\n      if (name === 'ttwid' || name === 'odin_tt' || \n          name === 'd_ticket' || name === 's_v_web_id') {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // TikTok CSRF tokens\n      if (name === 'tt_csrf_token' || name === 'csrfToken' ||\n          name.indexOf('passport_csrf_token') !== -1) {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // TikTok tokens และ chain\n      if (name === 'msToken' || name === 'tt_chain_token' || \n          name === 'cmpl_token' || name === '_waftokenid') {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // Store และ settings cookies\n      if (name.indexOf('store-') !== -1 || name.indexOf('tiktok_webapp_') !== -1 ||\n          name === 'tt-target-idc' || name === 'last_login_method') {\n        httpOnly = false;\n        secure = false;\n      }\n      \n      // Tracking และ cache cookies\n      if (name.indexOf('perf_feed_cache') !== -1 || \n          name.indexOf('passport_fe_beating') !== -1 ||\n          name === 'delay_guest_mode_vid') {\n        httpOnly = false;\n        secure = false;\n      }\n      \n      // TikTok session data และ IDC sign\n      if (name === 'tt_session_tlb_tag' || \n          name.indexOf('tt-target-idc-sign') !== -1) {\n        httpOnly = false;\n        secure = true;\n      }\n      \n      // G_state (similar to other platforms)\n      if (name.indexOf('g_state') !== -1) {\n        httpOnly = false;\n        secure = false;\n      }\n      \n      result.push({\n        name: name,\n        value: value,\n        domain: cookieDomain,\n        path: '/',\n        secure: secure,\n        httpOnly: httpOnly\n      });\n    }\n    \n    return result;\n  }\n  \n  // ===== แปลง Cookie String =====\n  let formatted;\n  try {\n    let cookiesArray = parseCookies(cookieString, domain);\n    \n    if (cookiesArray.length === 0) {\n      console.log('[Error] No cookies parsed. Check cookie string format.');\n      console.log('[Debug] Cookie string preview:', cookieString.substring(0, 100));\n      return '';\n    }\n    \n    formatted = JSON.stringify(cookiesArray);\n    \n    console.log('[Success] Formatted cookies count:', cookiesArray.length);\n    console.log('[Success] Cookie names:', cookiesArray.map(function(c) { return c.name; }).slice(0, 10).join(', ') + '...');\n    \n    // แสดงข้อมูล cookies สำคัญที่พบ\n    let authCookies = ['sessionid', 'sessionid_ss', 'sid_guard', 'ttwid', 'odin_tt'];\n    let foundAuth = [];\n    for (let i = 0; i < cookiesArray.length; i++) {\n      if (authCookies.indexOf(cookiesArray[i].name) !== -1) {\n        foundAuth.push(cookiesArray[i].name);\n      }\n    }\n    if (foundAuth.length > 0) {\n      console.log('[Info] Important TikTok cookies found:', foundAuth.join(', '));\n    }\n    \n  } catch (e) {\n    console.log('[Error] Error parsing cookies:', e);\n    return '';\n  }\n  \n  // ===== บันทึกข้อมูล =====\n  try {\n    if (typeof SetVariable === 'function') {\n      SetVariable('formatted', formatted);\n      console.log('[Success] Data saved to \"formatted\" variable');\n    }\n  } catch (e) {\n    console.log('[Error] Error setting variable:', e);\n  }\n  \n  return formatted;\n})();","preloadScripts":[],"everyNewTab":false,"runBeforeLoad":false,"delay":0,"$breakpoint":false},"label":"javascript-code","blockId":"jwyw5xf"},{"id":"xffz0rp","type":"BlockBasicWithFallback","initialized":false,"position":{"x":1455,"y":660},"data":{"icon":"riLink","disableBlock":false,"url":"https://www.tiktok.com/th-TH/","userAgent":"","description":"เปิดเว็บ","waitTabLoaded":false,"customUserAgent":false,"newTab":false,"active":true,"delay":"1000"},"label":"open-url","blockId":"xffz0rp"},{"id":"i6nlsr9","type":"BlockConditions","initialized":false,"position":{"x":1005,"y":270},"data":{"icon":"riAB","description":"","disableBlock":false,"conditions":[{"id":"e7D-FtGls2oZW3WhvpGVn","name":"Facebook","conditions":[{"id":"tcxYPWQWhPB6L-H9Qxmai","conditions":[{"id":"sIH3BMWr8wQ3eyRExZYJC","items":[{"type":"value","category":"value","data":{"value":"{{variables.platform_1}}"},"i