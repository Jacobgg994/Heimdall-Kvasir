BasicWithFallback", "initialized": false, "position": {"x": 3495.457470614499, "y": -180.0815850991553}, "data": {"icon": "riDatabase2Line", "disableBlock": false, "description": "", "dataList": [{"type": "variable", "name": "location", "value": "[\"Songkhla, Thailand\", \"Hat Yai\", \"Surat Thani\", \"Nakhon Ratchasima Thailand\", \"Udon Thani\", \"Chiang Rai, Thailand\", \"Phitsanulok\", \"Rayong\", \"Phra Nakhon Si Ayutthaya\", \"Ubon Ratchathani\", \"Buriram\", \"Roi Et\", \"Nakhon Si Thammarat\", \"Yala\", \"Lampang\", \"Nakhon Sawan\", \"Pattaya, Thailand\", \"Chanthaburi\", \"Kanchanaburi\", \"Nonthaburi\", \"Samut Prakan\", \"ประตูท่าแพ( THA PHAE GATE)\", \"อ่างแก้ว มหาวิทยาลัยเชียงใหม่\", \"ดอยอินทนนท์ Doi Inthanon เชียงใหม่\", \"ม่อนแจ่ม(Mon Cham)\", \"วัดร่องขุ่น White Temple Chiang Rai\", \"Choui Fong Tea ไร่ชาฉุยฟง\", \"Wat Phra That Doi Suthep\", \"แม่กําปอง\", \"ปาย Pai\", \"อุทยานแห่งชาติเขาใหญ่ ( KHOA YAI National Park )\", \"อนุสาวรีย์ท้าวสุรนารี ( ย่าโม )\", \"ตลาดเซฟวัน โคราช\", \"Primo Piazza at Khao Yai\", \"ถนนคนเดินเชียงคาน : Chiangkan Walking Street\", \"คำชะโนด\", \"มหาวิทยาลัยขอนแก่น | Khon Kaen University\", \"เซ็นทรัลพลาซ่า ขอนแก่น\", \"อุทยานแห่งชาติผาแต้ม\", \"ทุ่งดอกกระเจียว ชัยภูมิ\", \"Iconsiam, Bangkok, Thailand\", \"Siam Paragon,Bangkok,Thailand\", \"Wat Arun Temple วัดอรุณราชวราราม\", \"เสาชิงช้า หน้าวัดสุทัศน์\", \"เอเชียทริค เดอะ ริเวอร์ฟร้อนท์\", \"วัดพระศรีรัตนศาสดาราม-วัดพระแก้ว\", \"ตลาดนัดจตุจักร\", \"เซ็นทรัลเวิลด์ Centralworld\", \"เยาวราช (Yaowarat)\", \"วัดไชยวัฒนาราม อยุธยา\", \"หาดบางแสน_Bangsaen Beach\", \"Pattaya Beach\", \"สถาบันวิทยาศาสตร์ทางทะเล ม.บูรพา\", \"J-Park Sriracha Nihon Mura\", \"จุดชมวิว เขาสามมุข\", \"เกาะล้าน (Koh Larn)\", \"Sanctuary of Truth ปราสาทสัจธรรม\", \"ตลาดหนองมน ชลบุรี\", \"อ่าวคุ้งกระเบน-หาดแหลมเสด็จ\", \"เกาะช้าง (Koh Chang)\", \"สะพานข้ามแม่น้ำแคว เมืองกาญ\", \"ต้นจามจุรียักษ์ จ.กาญจนบุรี\", \"Safari Park, Kanchanaburi\", \"Erawan Waterfall น้ำตกเอรวัน\", \"หมู่บ้านอีต่อง ต.ปิล็อก อ.ทองผาภูมิ\", \"ตลาดน้ำดำเนินสะดวก จ.ราชบุรี\", \"เดอะ ซีนเนอรี่ วินเทจ ฟาร์ม สวนผึ้ง\", \"Cha-Am Beach หาดชะอำ\", \"Phuket Old Town ย่านเมืองเก่าภูเก็ต\", \"แหลมพรหมเทพ Prom Thep Cape\", \"Patong Beach, Phuket.(หาดป่าตอง ภูเก็ต)\", \"หาดกะตะ - Kata Beach Phuket\", \"ไอ้ไข่ วัดเจดีย์ นครศรีธรรมราช\", \"หมู่บ้านคีรีวง นครศรีธรรมราช\", \"อ่าวนาง Ao Nang, Krabi\", \"เกาะพีพี จ.กระบี่\", \"เซ็นทรัลเฟสติวัล ภูเก็ต\", \"หาดใหญ่ (Hatyai)\"]", "filePath": "", "isFile": false, "action": "default"}], "delay": 0, "block": "insertData", "blockId": "a251cp4"}, "label": "insert-data"}, {"id": "3jcew41", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 3495.4388239196564, "y": -101.28297033545778}, "data": {"icon": "riDatabase2Line", "disableBlock": false, "description": "", "dataList": [{"type": "variable", "name": "location_last", "value": "{{$randData([variables.location])}}", "filePath": "", "isFile": false, "action": "default"}], "delay": 0, "block": "insertData", "blockId": "3jcew41"}, "label": "insert-data", "blockId": "3jcew41"}, {"id": "6ydghyp", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 3493.6105380143845, "y": 122.98213312326342}, "data": {"icon": "riKeyboardLine", "disableBlock": false, "keys": "Control,a", "selector": "//input[@aria-label=\"Where are you?\" or @aria-label=\"คุณอยู่ที่ไหน?\" or @aria-label=\"คุณอยู่ที่ไหน\" or @aria-label=\"Bạn đang ở đâu?\" or @aria-label=\"Bạn đang ở đâu\" or @aria-label=\"Di mana Anda?\" or @aria-label=\"Di mana kamu?\" or @aria-label=\"ເຈົ້າຢູ່ໃສ?\" or @aria-label=\"ເຈົ້າຢູ່ໃສ\" or @aria-label=\"Где вы?\" or @aria-label=\"Где вы находитесь?\" or @aria-label=\"어디에 계신가요?\" or @aria-label=\"어디에 있나요?\" or @aria-label=\"今どこにいますか？\" or @aria-label=\"你在哪里？\" or @aria-label=\"你在哪裡？\" or @aria-label=\"你在哪里\" or @aria-label=\"你在哪裡\"]", "pressTime": "100", "action": "press-key", "description": "", "keysToPress": "{{variables.location_last}}", "level": "Browser", "findBy": "xpath", "delay":