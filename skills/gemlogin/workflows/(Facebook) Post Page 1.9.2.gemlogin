nd (starts-with(@aria-label, 'Send this to friends') or starts-with(@aria-label, 'ส่งสิ่งนี้ให้เพื่อน') or starts-with(@aria-label, 'Gửi') or starts-with(@aria-label, 'Kirim') or starts-with(@aria-label, 'ສົ່ງ') or starts-with(@aria-label, 'Отправь') or starts-with(@aria-label, 'Отправить') or starts-with(@aria-label, '友達に送る') or starts-with(@aria-label, '친구에게 보내') or starts-with(@aria-label, '发送给朋友') or starts-with(@aria-label, '傳送給朋友') or starts-with(@aria-label, 'ส่งให้เพื่อน'))]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "4000,6000", "humanClick": false, "settings": {"blockTimeout": "50000"}}, "label": "event-click", "blockId": "eadr9v3"}, {"id": "h272je3", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 5148.241307121435, "y": 1370.8202951782769}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Copy link", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@role='button'][.//span[text()='Copy link' or text()='คัดลอกลิงก์' or text()='Sao chép liên kết' or text()='Salin tautan' or text()='ຄัดลอกລິງກ໌' or text()='ຄัดลอกລິງ' or text()='Копировать ссылку' or text()='ลิงก์ 복사' or text()='ลิงก์ 복사' or text()='リンクをコピー' or text()='复制链接' or text()='複製連結']]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "", "humanClick": false, "settings": {"blockTimeout": "50000"}}, "label": "event-click", "blockId": "h272je3"}, {"id": "vsbx17d", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 5445.315649255345, "y": 1359.1773196444988}, "data": {"icon": "riClipboardLine", "disableBlock": false, "description": "เก็บเป็นตัวแปร", "type": "get", "assignVariable": true, "variableName": "LinkPost", "saveData": false, "dataColumn": "", "dataToCopy": "", "copySelectedText": false, "delay": 0}, "label": "clipboard", "blockId": "vsbx17d"}, {"id": "9o55hnd", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 5444.047234610397, "y": 1277.0483205793428}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "// 1. สร้างช่วงตัวเลข 30 ช่องอัตโนมัติ\nconst ranges = [];\nlet startNum = 1000; // จุดเริ่มต้นของช่องแรก\nconst gap = 1000;    // ระยะห่างของแต่ละช่อง (เช่น 1000-2000, 2000-3000)\n\nfor (let i = 0; i < 30; i++) {\n    ranges.push({\n        min: startNum + (i * gap),\n        max: startNum + ((i + 1) * gap) - 1\n    });\n}\n\n// 2. สุ่มเลือก 1 ใน 30 ช่อง\nlet randomSlotIndex = Math.floor(Math.random() * ranges.length);\nlet selectedRange = ranges[randomSlotIndex];\n\n// 3. สุ่มตัวเลขจริงภายในช่องที่เลือกได้\nlet min = selectedRange.min;\nlet max = selectedRange.max;\nlet finalRandomNumber = Math.floor(Math.random() * (max - min + 1)) + min;\n\n// 4. บันทึกค่าลงตัวแปร\nSetVariable('randomResult', finalRandomNumber);\nSetVariable('selectedSlot', randomSlotIndex + 1);\n\nconsole.log(`สุ่มได้ช่องที่: ${randomSlotIndex + 1} | ช่วง: ${min}-${max} | ค่าที่ได้: ${finalRandomNumber}`);\n\nNextBlock();", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code", "blockId": "9o55hnd"}, {"id": "yb2solf", "type": "BlockDelay", "initialized": false, "position": {"x": 5748.395729050525, "y": 1242.8155993756986}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "{{variables.randomResult}}"}, "label": "delay", "blockId": "yb2solf"}, {"id": "1r9emvh", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 4821.437929894503, "y": 1230.1144449516873}, "data": {"icon": "riFocus3Line", "disableBlock": false, "description": "", "findBy": "xpath", "selector": "//div[@role='button' and (starts-with(@aria-label, 'Send this to friends') or starts-with(@aria-label, 'ส่งสิ่งนี้ให้เพื่อน') or starts-with(@aria-label, 'Gửi') or starts-with(@aria-label, 'Kirim') or starts-with(@aria-label, 'ສົ່ງ') or starts-with(@a