(text(), '视频帖子') or contains(text(), '影片貼文')]", "tryCount": "1", "timeout": "500", "waitBetweenRetries": "", "markEl": false, "throwError": false, "delay": 0}, "label": "element-exists"}, {"id": "83u55se", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1034.149117330549, "y": 84.68926300665944}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//button[contains(@class, '_aswp') and (text()='OK' or text()='ตกลง' or text()='확인' or text()='ОК')]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click"}, {"id": "u8mby4k", "type": "BlockConditions", "initialized": false, "position": {"x": 2351.4378399306847, "y": 108.38483947906477}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "16Y1_JPhG5eWqDvQj3PwH", "name": "Path 1", "conditions": [{"id": "iTA-cp-R6xA3nkkGD52xV", "conditions": [{"id": "Hh6YjzF5IppVihCRow3t1", "items": [{"type": "element#exists", "category": "value", "data": {"selector": "//h3[text()='Your post has been shared.']"}, "id": "lapIg92g5yxfsSQTzPgXU"}]}]}, {"id": "Xy-bpfR85MNYa1NQVakYv", "conditions": [{"id": "qY9u4cqDUWE2J-z-_8SQT", "items": [{"type": "element#exists", "category": "value", "data": {"selector": "//h3[text()='Your reel has been shared.']"}, "id": "7fjmwb8sWWtgdo94iQ5_2"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "0we0n38", "type": "BlockDelay", "initialized": false, "position": {"x": 2400.279262939262, "y": 302.28226236060397}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "1000"}, "label": "delay"}, {"id": "aw7royu", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 702.8952129711968, "y": 1664.646377686923}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@class='x1i10hfl x1qjc9v5 xjbqb8w xjqpnuy xc5r6h4 xqeqjp1 x1phubyo x13fuv20 x18b5jzi x1q0q8m5 x1t7ytsu x972fbf x10w94by x1qhh985 x14e42zd x9f619 x1ypdohk xdl72j9 x2lah0s x3ct3a4 xdj266r x14z9mp xat24cr x1lziwak x2lwn1j xeuugli x1n2onr6 x16tdsg8 x1hl2dhg xggy1nq x1ja2u2z x1t137rt x1fmog5m xu25z0z x140muxe xo1y3bh x3nfvp2 x1q0g3np x87ps6o x1lku1pv x1a2a7pz x1epzrsm xpzwpp9 xus2keu x1y1aw1k xf159sx xwib8y2 xmzvs34']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click"}, {"id": "fqh1gg9", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 715.575709996819, "y": 1797.3346212895765}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "// 1. รับค่าตัวแปรเงื่อนไข (ดึงค่ามาจากระบบของคุณ)\nconst checkAll = RefData('variables', 'isAll'); // ค่านี้ต้องเป็น true หรือ false\nlet limit = RefData('variables', 'countshare');\n\n// 2. จัดการตัวแปร limit ตามเงื่อนไข checkAll\n// ถ้า checkAll เป็น true ให้ตั้ง limit เป็น Infinity (เก็บทั้งหมด)\nif (checkAll === true || checkAll === \"true\") {\n    limit = Infinity;\n} else {\n    limit = parseInt(limit);\n}\n\n// ตรวจสอบความถูกต้องของตัวเลข\nif (isNaN(limit)) {\n    limit = Infinity; \n}\n\n// 3. รายชื่อคำที่ไม่เอา (Blacklist)\nconst blacklist = [\"Home\", \"Reels\", \"Messages\", \"Search\", \"Explore\", \"Notifications\", \"Create\", \"Dashboard\", \"Profile\", \"More\", \"Also from Meta\", \"Instagram\", \"Verified\", \"Copy link\", \"See all\"];\n\n// 4. เลือก Element เฉพาะที่เป็นชื่อ IG\nconst nameElements = document.querySelectorAll('div[role=\"button\"] span.x1lliihq.x193iq5w.x6ikm8r.x10wlt62');\n\n// 5. วนลูปดึงค่า\nlet igNames = [];\n\nfor (let i = 0; i < nameElements.length; i++) {\n    // ถ้าเก็บครบตามจำนวนที่จำกัดไว้ (และไม่ใช่โหมดเก็บทั้งหมด) ให้หยุด\n    if (igNames.length >= limit) break;\n\n    let name = nameElements[i].innerText.trim();\n\n    // กรองข้อมูลที่ไม่อยู่ใน Blacklist\n    if (name !== \"\" && !blacklist.includes(name)) {\n        igNames.push(name);\n    }\n}\n\n// 6. ส่งค่ากลับเข้าตัวแปรระบบ\nconsole.log(`โหมดดึงทั้งหมด: ${limit === Infinity ? \"เปิด\" : \"ปิด\"}`);\nconsole.log(`สรุป: เก็บชื่อมาได้ ${igNames.length} คน`);\n\nSetVariable(\"name\", igNames);\n\n// แสดงผลใน Console เพื่อ Debug\nif (igNames.length > 0) {\n    console.log(\"รายชื่อที่เก็บได้:\", igNames);\n} else {\n    console.log(\"ไม่พบชื่อที่ตรงตามเงื่อนไข\");\n}", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code"}, {"id": "lnkjq70", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1013.8452303547033, "y": 1596.156045041131}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@role=\"button\"][.//span[text()=\"{{loopData.U6hQGQ}}\"]]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "500", "humanClick": true}, "label": "event-click"}, {"id": "0963l76", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1016.4822795189389, "y": 1332.5490505895261}, "data": {"icon": "riRefreshLine", "disableBlock": false, "loopId": "U6hQGQ", "maxLoop": 0, "toNumber": 10, "fromNumber": 1, "startIndex": 0, "loopData": "[]", "description": "", "variableName": "name", "referenceKey": "", "reverseLoop": false, "elementSelector": "", "waitForSelector": false, "waitSelectorTimeout": 5000, "resumeLastWorkflow": false, "loopThrough": "variable", "delay": 0}, "label": "loop-data"}, {"id": "xvhhg46", "type": "BlockLoopBreakpoint", "initialized": false, "position": {"x": 1040.3193248816199, "y": 1709.2493924438293}, "data": {"icon": "riStopLine", "disableBlock": false, "loopId": "U6hQGQ", "clearLoop": false}, "label": "loop-breakpoint"}, {"id": "4tibb9p", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1027.2773168508222, "y": 1465.3311565650422}, "data": {"icon": "riMouseLine", "disableBlock": false, "description": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@role=\"button\"][.//span[text()=\"{{loopData.U6hQGQ}}\"]]", "markEl": false, "multiple": false, "scrollY": "", "scrollX": "", "humanScroll": false, "incX": false, "incY": false, "x": "", "y": "", "smooth": false, "scrollIntoView": true, "delay": "500"}, "label": "element-scroll"}, {"id": "e1if5cs", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2292.4291385821534, "y": 1458.1095060344962}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[text()='Send' or text()='ส่ง' or text()='Gửi' or text()='Kirim' or text()='ສົ່ງ' or text()='Отправить' or text()='보내기' or text()='送信' or text()='送信する' or text()='发送' or text()='傳送']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click"}, {"id": "jxawavd", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2327.8989941232903, "y": 1798.11765321137}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[text()='Send separately' or text()='ส่งแยก' or text()='ส่งแยกกัน' or text()='Gửi riêng' or text()='Kirim secara terpisah' or text()='ສົ່ງແຍກ' or text()='Отправить отдельно' or text()='따로 보내기' or text()='개별 전송' or text()='個別に送信' or text()='单独发送' or text()='個別傳送']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click"}, {"id": "131yg5m", "type": "BlockConditions", "initialized": false, "position": {"x": 1815.1537908840137, "y": 1585.344530817738}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "3LCv4haATneSt0bH89Rkw", "name": "Path 1", "conditions": [{"id": "jgDufD66RmtuHPOSIzDMj", "conditions": [{"id": "lgV4KAuKRkNhLxkT_WmIa", "items": [{"type": "element#exists", "category": "value", "data": {"selector": "//div[text()='Send' or text()='ส่ง' or text()='Gửi' or text()='Kirim' or text()='ສົ່ງ' or text()='Отправить' or text()='보내기' or text()='送信' or text()='送信する' or text()='发送' or text()='傳送']"}, "id": "R6XU4ak5rmA5hBsUyRVeH"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "cc2s01z", "type": "BlockConditions", "initialized": false, "position": {"x": -717.6344630141009, "y": 366.37808308732946}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "XrAIhMkhhf4AgBROtsozd", "name": "check select post", "conditions": [{"id": "OK6Rg_L2lxlZ-zyKXSX02", "conditions": [{"id": "0HsEnoHhWM-mSZArOMkhM", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectpost}}"}, "id": "yix48dY6rW9Eqt6f1CEGD"}, {"category": "compare", "type": "itr", "id": "vNbYqzFv44cZelnotLdw_"}]}, {"id": "na_x5CB5BUP3u8ZXe1OL7", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectshare}}"}, "id": "xXyZJm4jpRjtSziLxAzre"}, {"category": "compare", "type": "ifl", "id": "_3jqj0smy1agAH-2TYy_I"}]}]}]}, {"id": "f2b6gPh7zBX6icF17D6-d", "name": "check select share", "conditions": [{"id": "0CQOYkslnJvyiLd7sNvrD", "conditions": [{"id": "VaHy7zwjv6KpKSs4hxH2s", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectshare}}"}, "id": "zzOR9zmkXO8bpav8edtwo"}, {"category": "compare", "type": "itr", "id": "E8mfFhdRv9GYadecNwJCJ"}]}, {"id": "0_bRqInncxWHh2AVHNsv9", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectpost}}"}, "id": "nz51yPO8jYGMmvEKNWldC"}, {"category": "compare", "type": "ifl", "id": "xAcMyHAihzcBwRwQysOR9"}]}]}]}, {"id": "goaB7hNixCtmldSXkMbcp", "name": "check select post & share", "conditions": [{"id": "lgjEuL7EyriQ7iV-VagUq", "conditions": [{"id": "dLd5PKKQCxpq7RvFkLn4g", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectshare}}"}, "id": "c5TWFWRIrLPOb2DjkH2sK"}, {"category": "compare", "type": "itr", "id": "QjID88CBZAYXzqOq7YZqo"}]}, {"id": "tPsLcmLacara0Cx03w6Lb", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectpost}}"}, "id": "KsanLbz_x6wsOLYchQT61"}, {"category": "compare", "type": "itr", "id": "uxJA1CHKngkmEhDq5wUTb"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "nt3uaak", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2064.203394752201, "y": 420.9048819685972}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//button[contains(@class, '_acmx')]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click"}, {"id": "1adjq43", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 3193.3782689294694, "y": 731.3134609090482}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "function getFirstPostUrl() {\n    // 1. ถ้าตอนนี้อยู่ในหน้าโพสต์อยู่แล้ว ให้ใช้ URL นั้นเลย\n    const pathMatch = window.location.pathname.match(/^\\/(?:p|reel|reels)\\/[^/]+\\/?/);\n    if (pathMatch) {\n        return window.location.origin + pathMatch[0];\n    }\n\n    // 2. หา link แรกใน grid — ไม่สน class ที่เปลี่ยนบ่อย\n    const allLinks = Array.from(document.querySelectorAll('a[href]'));\n\n    const firstPost = allLinks.find(a => {\n        const href = a.getAttribute('href') || '';\n        // รองรับ /p/ABC123, /reel/ABC123, /username/reel/ABC123, /reels/ABC123\n        return /\\/(p|reel)\\/[^/?#]+/.test(href) || /\\/reels\\/[^/?#]+/.test(href);\n    });\n\n    if (firstPost) {\n        let url = firstPost.getAttribute('href');\n        // ทำให้เป็น absolute URL\n        if (url.startsWith('/')) {\n            url = 'https://www.instagram.com' + url;\n        }\n        // ตัด query string ออก\n        return url.split('?')[0];\n    }\n\n    // 3. ไม่เจออะไรเลย ให้คืน URL ปัจจุบัน\n    return window.location.href;\n}\n\n// นำไปใช้\nlet myPostUrl = getFirstPostUrl();\nconsole.log(\"URL ที่ได้คือ:\", myPostUrl);\nSetVariable(\"link\", myPostUrl);", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code"}, {"id": "kljp0qq", "type": "BlockConditions", "initialized": false, "position": {"x": 3216.528417333679, "y": 154.841386088685}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "XB09INMNV32G0-r9Bx_os", "name": "check share after post", "conditions": [{"id": "jcg5fVir_zL2-WWdwYzmM", "conditions": [{"id": "p3jLSP3G4zhTis2CqqEC8", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectshare}}"}, "id": "I_TxVSRAg9_AELOn-8bMg"}, {"category": "compare", "type": "itr", "id": "kQeC9btuc9EnocUJgC1k2"}]}, {"id": "Ju3gT135S3qVssPmeh2pM", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.selectpost}}"}, "id": "UvtHqblbOG9dU4USv6KW8"}, {"category": "compare", "type": "itr", "id": "drCMt44LenHl6BHiOkKnd"}]}, {"id": "KwZ9UzNsNZWB1PxsiQhsT", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.share_after_post}}"}, "id": "zI5_IctTeNx9JP6VKN2oa"}, {"category": "compare", "type": "itr", "id": "omPf1wIOwMmbeD7114gJh"}]}]}]}, {"id": "YSsH2C0KY-IG