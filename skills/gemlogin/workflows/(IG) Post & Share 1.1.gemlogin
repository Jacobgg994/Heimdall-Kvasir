, "id": "QteD2DRpulf546VF2fpYy"}, {"category": "compare", "type": "itr", "id": "C_RXVQ4KWbAjpXBOhrIPY"}]}, {"id": "1HsEnDZH2IgRTNixBH-Fk", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.share_after_post}}"}, "id": "AZbYhojsNakt7byo9vvSM"}, {"category": "compare", "type": "itr", "id": "bBKjfqbXhlAPkD5DbUjPh"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "jcotmgh", "type": "BlockNote", "initialized": false, "position": {"x": -902.0384479886854, "y": 250.98098810746217}, "data": {"icon": "riFileEditLine", "disableBlock": false, "note": "ตรวจสอบว่าผู้ใช้เลือก โพสต์, แชร์ หรือ เลือกทั้งสองอย่าง", "drawing": false, "width": 608, "height": 391, "color": "cream", "fontSize": "large"}, "label": "note"}, {"id": "iylt8ed", "type": "BlockNote", "initialized": false, "position": {"x": 141.9655423821535, "y": -354.3215211966709}, "data": {"icon": "riFileEditLine", "disableBlock": false, "note": "Upload รูป หรือ วิดีโอ", "drawing": false, "width": 1477, "height": 655, "color": "peach", "fontSize": "large"}, "label": "note"}, {"id": "g5sc6w2", "type": "BlockNote", "initialized": false, "position": {"x": 2960.608804487041, "y": -55.8911633424608}, "data": {"icon": "riFileEditLine", "disableBlock": false, "note": "ตรวจสอบว่าผู้ใช้ต้องการแชร์โพสต์ที่พึ่งโพสต์ไปหรือไม่", "drawing": false, "width": 691, "height": 924, "color": "mint", "fontSize": "large"}, "label": "note"}, {"id": "w08zc17", "type": "BlockNote", "initialized": false, "position": {"x": 422.94639497549133, "y": 2298.9588290660918}, "data": {"icon": "riFileEditLine", "disableBlock": false, "note": "                                                                                             \n                                                                                                                    เข้าสู่โพสต์ที่ต้องการแชร์ เช็ค ว่าต้องการแชร์ให้ผู้ใช้ทั้งหมดหรือตามจำนวนที่ตั้งไว้ จากนั้นกดแชร์\n                                                                                                                    หากมีมากกว่า 1 โพสต์จะลูปกลับมาเริ่มแชร์โพสต์ต่อไปจนครบ", "drawing": false, "width": 2773, "height": 1156, "color": "slate", "fontSize": "large"}, "label": "note"}, {"id": "fvh9fp6", "type": "BlockNote", "initialized": false, "position": {"x": 1841.152923306951, "y": -455.05815827158233}, "data": {"icon": "riFileEditLine", "disableBlock": false, "note": "ใส่ Caption และ Location จากนั้นทำการโพสต์", "drawing": false, "width": 837, "height": 1038, "color": "lavender", "fontSize": "large"}, "label": "note"}, {"id": "3grv44j", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2059.8402886473505, "y": 288.5710115047086}, "data": {"icon": "riFocus3Line", "disableBlock": false, "description": "", "findBy": "xpath", "selector": "//button[contains(@class, '_acmx')]", "tryCount": "1", "timeout": "500", "waitBetweenRetries": "0", "markEl": false, "throwError": false, "delay": 0}, "label": "element-exists"}, {"id": "42mqglz", "type": "BlockDelay", "initialized": false, "position": {"x": 3220.652624365251, "y": 579.7855831475594}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "5000"}, "label": "delay"}, {"id": "19ln0d4", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 684.4397674910116, "y": 1487.444737887087}, "data": {"icon": "riLink", "disableBlock": false, "url": "{{variables.link}}", "userAgent": "", "description": "", "waitTabLoaded": false, "waitForNavigation": "domcontentloaded", "customUserAgent": false, "newTab": false, "active": true, "delay": "1000"}, "label": "open-url", "blockId": "19ln0d4"}, {"id": "ooxan28", "type": "BlockDelay", "initialized": false, "position": {"x": 1329.5199246553013, "y": 1630.076565645896}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "2000"}, "label": "delay"}, {"id": "avu96cp", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 964.6042057677737, "y": 2939.054294140685}, "data": {"icon": "riLink", "disableBlock": false, "url": "{{loopData.bQR7RS}}", "userAgent": "", "description": "", "waitTabLoaded": false, "waitForNavigation": "domcontentloaded", "customUserAgent": false, "newTab": false, "active": true, "delay": "1000"}, "label": "open-url", "blockId": "avu96cp"}, {"id": "uxndxxi", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 954.2423897894182, "y": 3064.702923984324}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@class='x1i10hfl x1qjc9v5 xjbqb8w xjqpnuy xc5r6h4 xqeqjp1 x1phubyo x13fuv20 x18b5jzi x1q0q8m5 x1t7ytsu x972fbf x10w94by x1qhh985 x14e42zd x9f619 x1ypdohk xdl72j9 x2lah0s x3ct3a4 xdj266r x14z9mp xat24cr x1lziwak x2lwn1j xeuugli x1n2onr6 x16tdsg8 x1hl2dhg xggy1nq x1ja2u2z x1t137rt x1fmog5m xu25z0z x140muxe xo1y3bh x3nfvp2 x1q0g3np x87ps6o x1lku1pv x1a2a7pz x1epzrsm xpzwpp9 xus2keu x1y1aw1k xf159sx xwib8y2 xmzvs34']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click", "blockId": "uxndxxi"}, {"id": "0fsxtf7", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 966.9228868150403, "y": 3197.3911675869776}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "// 1. รับค่าตัวแปรเงื่อนไข (ดึงค่ามาจากระบบของคุณ)\nconst checkAll = RefData('variables', 'isAll'); // ค่านี้ต้องเป็น true หรือ false\nlet limit = RefData('variables', 'countshare');\n\n// 2. จัดการตัวแปร limit ตามเงื่อนไข checkAll\n// ถ้า checkAll เป็น true ให้ตั้ง limit เป็น Infinity (เก็บทั้งหมด)\nif (checkAll === true || checkAll === \"true\") {\n    limit = Infinity;\n} else {\n    limit = parseInt(limit);\n}\n\n// ตรวจสอบความถูกต้องของตัวเลข\nif (isNaN(limit)) {\n    limit = Infinity; \n}\n\n// 3. รายชื่อคำที่ไม่เอา (Blacklist)\nconst blacklist = [\"Home\", \"Reels\", \"Messages\", \"Search\", \"Explore\", \"Notifications\", \"Create\", \"Dashboard\", \"Profile\", \"More\", \"Also from Meta\", \"Instagram\", \"Verified\", \"Copy link\", \"See all\"];\n\n// 4. เลือก Element เฉพาะที่เป็นชื่อ IG\nconst nameElements = document.querySelectorAll('div[role=\"button\"] span.x1lliihq.x193iq5w.x6ikm8r.x10wlt62');\n\n// 5. วนลูปดึงค่า\nlet igNames = [];\n\nfor (let i = 0; i < nameElements.length; i++) {\n    // ถ้าเก็บครบตามจำนวนที่จำกัดไว้ (และไม่ใช่โหมดเก็บทั้งหมด) ให้หยุด\n    if (igNames.length >= limit) break;\n\n    let name = nameElements[i].innerText.trim();\n\n    // กรองข้อมูลที่ไม่อยู่ใน Blacklist\n    if (name !== \"\" && !blacklist.includes(name)) {\n        igNames.push(name);\n    }\n}\n\n// 6. ส่งค่ากลับเข้าตัวแปรระบบ\nconsole.log(`โหมดดึงทั้งหมด: ${limit === Infinity ? \"เปิด\" : \"ปิด\"}`);\nconsole.log(`สรุป: เก็บชื่อมาได้ ${igNames.length} คน`);\n\nSetVariable(\"name\", igNames);\n\n// แสดงผลใน Console เพื่อ Debug\nif (igNames.length > 0) {\n    console.log(\"รายชื่อที่เก็บได้:\", igNames);\n} else {\n    console.log(\"ไม่พบชื่อที่ตรงตามเงื่อนไข\");\n}", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code", "blockId": "0fsxtf7"}, {"id": "t9o9l2l", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1265.1924071729247, "y": 2996.212591338532}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@role=\"button\"][.//span[text()=\"{{loopData.U6hQGQ}}\"]]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "500", "humanClick": true}, "label": "event-click", "blockId": "t9o9l2l"}, {"id": "45ng0w7", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1267.8294563371603, "y": 2732.6055968869273}, "data": {"icon": "riRefreshLine", "disableBlock": false, "loopId": "U6hQGQ", "maxLoop": 0, "toNumber": 10, "fromNumber": 1, "startIndex": 0, "loopData": "[]", "description": "", "variableName": "name", "referenceKey": "", "reverseLoop": false, "elementSelector": "", "waitForSelector": false, "waitSelectorTimeout": 5000, "resumeLastWorkflow": false, "loopThrough": "variable", "delay": 0}, "label": "loop-data", "blockId": "45ng0w7"}, {"id": "764scty", "type": "BlockLoopBreakpoint", "initialized": false, "position": {"x": 1291.6665016998413, "y": 3109.3059387412304}, "data": {"icon": "riStopLine", "disableBlock": false, "loopId": "U6hQGQ", "clearLoop": false}, "label": "loop-breakpoint", "blockId": "764scty"}, {"id": "7xyeft1", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1278.6244936690437, "y": 2865.3877028624433}, "data": {"icon": "riMouseLine", "disableBlock": false, "description": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[@role=\"button\"][.//span[text()=\"{{loopData.U6hQGQ}}\"]]", "markEl": false, "multiple": false, "scrollY": "", "scrollX": "", "humanScroll": false, "incX": false, "incY": false, "x": "", "y": "", "smooth": false, "scrollIntoView": true, "delay": "500"}, "label": "element-scroll", "blockId": "7xyeft1"}, {"id": "qks344p", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2543.776315400375, "y": 2858.1660523318974}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//div[text()='Send' or text()='ส่ง' or text()='Gửi' or text()='Kirim' or text()='ສົ່ງ' or text()='Отправить' or text()='보내기' or text()='送信' or text()='送信する' or text()='发送' or text()='傳送']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "1000", "humanClick": true}, "label": "event-click", "blockId": "qks344p"}, {"id": "zbi8pdk"