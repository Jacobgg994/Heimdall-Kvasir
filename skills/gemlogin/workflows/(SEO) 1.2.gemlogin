dex": "0", "loopData": "[]", "description": "GPwktF", "variableName": "all_link", "referenceKey": "", "reverseLoop": false, "elementSelector": "", "waitForSelector": false, "waitSelectorTimeout": 5000, "resumeLastWorkflow": false, "loopThrough": "variable", "delay": 0}, "label": "loop-data"}, {"id": "5vqigrn", "type": "BlockLoopBreakpoint", "initialized": false, "position": {"x": 1807.5974873996427, "y": 505.08234461266346}, "data": {"icon": "riStopLine", "disableBlock": false, "loopId": "GPwktF", "clearLoop": false}, "label": "loop-breakpoint"}, {"id": "e96zq9s", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 544.2978047697184, "y": -252.94320773882333}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "Get link", "timeout": "20000", "context": "website", "code": "// ดึงลิงก์ทั้งหมดจากทุกหน้าเว็บ\nconst GetLink = [...document.querySelectorAll('a[href]')]\n    .map(a => a.href.trim())\n    .filter(link => link) // ตัดค่าว่าง\n    .filter((link, index, self) => self.indexOf(link) === index); // ลบลิงก์ซ้ำ\n\n// เก็บตัวแปร\nSetVariable(\"GetLink\", GetLink);\n\nconsole.log(GetLink);", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": "2000"}, "label": "javascript-code"}, {"id": "wdxkujb", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 548.1558102095523, "y": -178.12703430895937}, "data": {"icon": "riLink", "disableBlock": false, "url": "{{$randData([variables.GetLink])}}", "userAgent": "", "description": "", "waitTabLoaded": false, "waitForNavigation": "domcontentloaded", "customUserAgent": false, "newTab": false, "active": true, "delay": 0}, "label": "open-url"}, {"id": "g0a1zz3", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": -466.46544781220973, "y": 319.9734038292975}, "data": {"icon": "riFileTextLine", "disableBlock": false, "description": "", "path": "{{variables.postLinksTextFilePath}}", "delimiter": "", "assignVariable": false, "variableName": "all_link", "randomEnable": false, "deleteLine": false, "mode": "allLines", "delay": 0}, "label": "read-file-text"}, {"id": "nd8wtid", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": -187.97708666062377, "y": 586.1363817276902}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "// หาโพสต์\nconst postElement = document.querySelector(\n    '[data-ad-rendering-role=\"story_message\"]'\n);\n\nif (postElement) {\n\n    // หา link ทุกตัวในโพสต์\n    const links = [...postElement.querySelectorAll('a[href]')];\n\n    for (const a of links) {\n\n        let href = a.href || \"\";\n\n        try {\n\n            // ถ้าเป็น redirect ของ Facebook\n            if (href.includes(\"l.facebook.com/l.php\")) {\n\n                const fbUrl = new URL(href);\n\n                href = decodeURIComponent(\n                    fbUrl.searchParams.get(\"u\") || href\n                );\n            }\n\n            // ลบ fbclid\n            const cleanUrl = new URL(href);\n\n            cleanUrl.searchParams.delete(\"fbclid\");\n\n            href = cleanUrl.toString();\n\n        } catch {}\n\n        // เอาเฉพาะลิงก์ภายนอก\n        if (\n            href.startsWith(\"http\") &&\n            !href.includes(\"facebook.com\")\n        ) {\n\n            console.log(\"FOUND =\", href);\n\n            // เก็บตัวแปร\n            SetVariable(\"LinkSeo\", href);\n\n            // เปิดแท็บเดิม\n            window.location.href = href;\n\n            break;\n        }\n    }\n}", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": "3000"}, "label": "javascript-code", "blockId": "nd8wtid"}, {"id": "r9dvczi", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 139.56037233717132, "y": -274.368859821888}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "", "timeout": "20000", "context": "website", "code": "// หาโพสต์\nconst postElement = document.querySelector(\n    '[data-ad-rendering-role=\"story_message\"]'\n);\n\nif (postElement) {\n\n    // หา link ทุกตัวในโพสต์\n    const links = [...postElement.querySelectorAll('a[href]')];\n\n    for (const a of links) {\n\n        let href = a.href || \"\";\n\n        try {\n\n            // ถ้าเป็น redirect ของ Facebook\n            if (href.includes(\"l.facebook.com/l.php\")) {\n\n                const fbUrl = new URL(href);\n\n                href = decodeURIComponent(\n                    fbUrl.searchParams.get(\"u\") || href\n                );\n            }\n\n            // ลบ fbclid\n            const cleanUrl = new URL(href);\n\n            cleanUrl.searchParams.delete(\"fbclid\");\n\n            href = cleanUrl.toString();\n\n        } catch {}\n\n        // เอาเฉพาะลิงก์ภายนอก\n        if (\n            href.startsWith(\"http\") &&\n            !href.includes(\"facebook.com\")\n        ) {\n\n            console.log(\"FOUND =\", href);\n\n            // เก็บตัวแปร\n            SetVariable(\"LinkSeo\", href);\n\n            // กดลิงก์\n            a.click();\n\n            break;\n        }\n    }\n}", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code"}, {"id": "ekkbjzh", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 704.6114946969549, "y": 563.7050814020581}, "data": {"icon": "riDeleteBin7Line", "disableBlock": false, "description": "", "deleteList": [{"type": "variable", "variableName": "Random1", "columnId": "[all]"}], "delay": "1000"}, "label": "delete-data"}, {"id": "wd4ahol", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1609.0988982920487, "y": 1124.3578116067608}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "Get link", "timeout": "20000", "context": "website", "code": "// ดึงลิงก์ทั้งหมด\nconst GetLink = [...document.querySelectorAll('a[href]')]\n    .map(a => a.href.trim())\n    .filter(link => link)\n    .filter((link, index, self) =>\n        self.indexOf(link) === index\n    );\n\n// เก็บตัวแปร\nSetVariable(\"GetLink\", GetLink);\n\n// สุ่ม\nconst randomIndex =\n    Math.floor(Math.random() * GetLink.length);\n\nconst randomLink = GetLink[randomIndex];\n\n// เก็บลิงก์ที่สุ่ม\nSetVariable(\"RandomLink\", randomLink);\n\nconsole.log(randomLink);\n\n// เปิดแท็บเดิม\nwindow.location.href = randomLink;", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": "5000"}, "label": "javascript-code", "blockId": "wd4ahol"}, {"id": "7s8ngn7", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 127.63892415900727, "y": -370.2785650916702}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "Get link", "timeout": "20000", "context": "website", "code": "// ดึงลิงก์จากโพสต์\nconst postElement = document.querySelector('[data-ad-rendering-role=\"story_message\"]');\n\n// หา <a> ทั้งหมดในโพสต์\nconst links = [...postElement.querySelectorAll('a[href]')];\n\n// เอาลิงก์จริงออกจาก facebook redirect + ลบ fbclid\nconst LinkSeo = links.map(a => {\n\n    let href = a.href;\n\n    // ถ้าเป็นลิงก์ redirect ของ Facebook\n    if (href.includes('l.facebook.com/l.php')) {\n\n        const redirectUrl = new URL(href);\n\n        href = decodeURIComponent(\n            redirectUrl.searchParams.get('u') || href\n        );\n    }\n\n    try {\n\n        const cleanUrl = new URL(href);\n\n        // ลบ fbclid\n        cleanUrl.searchParams.delete(\"fbclid\");\n\n        return cleanUrl.toString();\n\n    } catch {\n\n        return href;\n    }\n\n})[0] || \"\";\n\n// เก็บค่า\nSetVariable(\"LinkSeo\", LinkSeo);\n\nconsole.log(LinkSeo);", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code"}, {"id": "igl9sqh", "type": "BlockRepeatTask", "initialized": false, "position": {"x": 1363.1951952510017, "y": 377.2484887586237}, "data": {"icon": "riRepeat2Line", "disableBlock": false, "repeatFor": "{{variables.Random2}}"}, "label": "repeat-task", "blockId": "igl9sqh"}, {"id": "c28lr6q", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1394.3859568515966, "y": 596.9709152492144}, "data": {"icon": "riDeleteBin7Line", "disableBlock": false, "description": "", "deleteList": [{"type": "variable", "variableName": "Random1", "columnId": "[all]"}], "delay": "1000"}, "label": "delete-data", "blockId": "c28lr6q"}, {"id": "2afw0q3", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1108.4054500430702, "y": 370.3733338877263}, "data": {"icon": "riDiceLine", "disableBlock": false, "description": "", "language": "EN", "type": "number", "categories": "simple", "fromNumber": "10", "toNumber": "29", "command": "", "variableName": "Random1", "delay": 0}, "label": "random", "blockId": "2afw0q3"}, {"id": "pt1i6qb", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1107.094069429365, "y": 445.14293345171245}, "data": {"icon": "riDiceLine", "disableBlock": false, "description": "", "language": "EN", "type": "number", "categories": "simple", "fromNumber": "6", "toNumber": "3", "command": "", "variableName": "Random2", "delay": 0}, "label": "random", "blockId": "pt1i6qb"}, {"id": "1ttr6yc", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 642.7781242890466, "y": 941.6491182928586}, "data": {"icon": "riMouseLine", "disableBlock": false, "description": "", "findBy": "cssSelector", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "html", "markEl": false, "multiple": false, "scrollY": "{{variables.Random1}}00", "scrollX": "", "humanScroll": false, "incX": false, "incY": true, "x": "", "y": "", "smooth": true, "scrollIntoView": false, "delay": "3000"}, "label": "element-scroll", "blockId": "1ttr6yc"}, {"id": "xcf88zh", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 518.1096188365923, "y": 778.3478