ized": false, "position": {"x": 1399.9668341676922, "y": 976.0555939148778}, "data": {"icon": "riFocus3Line", "disableBlock": false, "description": "ตรวจสอบ whatsApp popup", "findBy": "xpath", "selector": "//span[normalize-space()='Add WhatsApp button' or normalize-space()='เพิ่มปุ่ม WhatsApp' or normalize-space()='Thêm nút WhatsApp' or normalize-space()='Tambahkan tombol WhatsApp' or normalize-space()='ເພີ່ມປຸ່ມ WhatsApp' or normalize-space()='Добавить кнопку WhatsApp' or normalize-space()='WhatsApp 버튼 추가' or normalize-space()='WhatsAppボタンを追加' or normalize-space()='添加 WhatsApp 按钮' or normalize-space()='新增 WhatsApp 按鈕']", "tryCount": "1", "timeout": "500", "waitBetweenRetries": "0", "markEl": false, "throwError": false, "delay": 0}, "label": "element-exists", "blockId": "pjslwn6"}, {"id": "rgibs9f", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1665.567330640702, "y": 962.3341887101595}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Not now", "x": "", "y": "", "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "//span[normalize-space()='Not now' or normalize-space()='ไม่ใช่ตอนนี้' or normalize-space()='Không phải bây giờ' or normalize-space()='Lain kali' or normalize-space()='Tidak sekarang' or normalize-space()='ບໍ່ແມ່ນຕອນນີ້' or normalize-space()='ໄວ້ກ່อน' or normalize-space()='Не сейчас' or normalize-space()='나중에' or normalize-space()='지금은 안 함' or normalize-space()='지금은 안함' or normalize-space()='今はしない' or normalize-space()='後で' or normalize-space()='不是现在' or normalize-space()='以后再说' or normalize-space()='暫不' or normalize-space()='暂不' or normalize-space()='以後再說']", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": "5000", "humanClick": true, "settings": {"blockTimeout": "10000"}}, "label": "event-click", "blockId": "rgibs9f"}, {"id": "jscezwe", "type": "BlockBasic", "initialized": false, "position": {"x": 1685.569155539659, "y": 1069.7496781410591}, "data": {"icon": "riFlagLine"}, "label": "end"}, {"id": "3tfagi0", "type": "BlockDelay", "initialized": false, "position": {"x": 1403.693899059715, "y": 1051.284821911517}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "{{variables.delay}}000"}, "label": "delay", "blockId": "3tfagi0"}, {"id": "9t2pmd0", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1458.869701232874, "y": 291.16783214130595}, "data": {"icon": "riKeyboardLine", "disableBlock": false, "keys": "", "selector": "//div[@role=\"textbox\" and (starts-with(@aria-placeholder, \"What's on your mind\") or starts-with(@aria-placeholder, \"คุณกำลังคิดอะไรอยู่\") or starts-with(@aria-placeholder, \"Bạn đang nghĩ gì\") or starts-with(@aria-placeholder, \"Apa yang Anda pikirkan\") or starts-with(@aria-placeholder, \"Apa yang dipikirkan\") or starts-with(@aria-placeholder, \"ເຈົ້າກຳລັງຄິດ\") or starts-with(@aria-placeholder, \"ท่านກຳລັງຄິດ\") or starts-with(@aria-placeholder, \"Что у вас\") or starts-with(@aria-placeholder, \"무슨 생각\") or starts-with(@aria-placeholder, \"今なにしてる\") or starts-with(@aria-placeholder, \"在想什么\") or starts-with(@aria-placeholder, \"你在想\"))]", "pressTime": "0", "action": "multiple-keys", "description": "Type Hashtags", "keysToPress": " #{{loopData.loop_hashtag}}", "level": "Browser", "findBy": "xpath", "delay": "1000", "settings": {"blockTimeout": "10000"}, "$breakpoint": false}, "label": "press-key", "blockId": "9t2pmd0"}, {"id": "74ejxf4", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1458.3578170535975, "y": 364.6458146605309}, "data": {"icon": "riKeyboardLine", "disableBlock": false, "keys": "Enter", "selector": "", "pressTime": "0", "action": "press-key", "description": "enter", "keysToPress": "", "level": "Browser", "findBy": "cssSelector", "delay": 0}, "label": "press-key", "blockId": "74ejxf4"}, {"id": "bct51oy", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1206.247981999508, "y": 250.1560439057028}, "data": {"icon": "riSortAsc", "disableBlock": false, "description": "", "valueSplit": "{{variables.hashtag}}", "delimiter": ",", "mode": "allValue", "indexPosition": 1, "assignVariable": true, "variableName": "hashtag", "isTrimWhitespaces": true, "delay": 0}, "label": "split-data"}, {"id": "q79nlmj", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2109.018190370247, "y": 705.1380354908142}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "แปลงลิงก์ google drive ให้เป็นลิงก์ที่สามารถคัดลอกได้", "timeout": "20000", "context": "website", "code": "const driveUrl = RefData('variables', 'loopimage')\n\n// แปลงเป็น Direct Link ในบรรทัดเดียว\nconst directLink = driveUrl.replace(/.*\\/d\\/([^/?]+).*/, \"https://drive.google.com/uc?export=download&id=$1\");\n\nSetVariable('loopimage', directLink)\n// ผลลัพธ์: https://drive.google.com/uc?export=download&id=1A2B3C4D5E6F7G8H9I0J", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code", "blockId": "q79nlmj"}, {"id": "bpkn0sl", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2391.573041184556, "y": 684.8255813918277}, "data": {"icon": "riTerminalBoxLine", "command": "curl -L -k -A \"Mozilla/5.0\" \"{{variables.loopimage}}\" -o /tmp/temp_fb.jpg && osascript -e 'set the clipboard to (read (POSIX file \"/tmp/temp_fb.jpg\") as JPEG picture)'", "type": "terminal", "regex": "", "variableName": "", "assignVariable": false, "delay": 0, "description": "MacOS"}, "label": "commandPro", "blockId": "bpkn0sl"}, {"id": "q5bpp62", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2657.0495447368367, "y": 686.9467859451083}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "วางสำรอง", "timeout": "20000", "context": "website", "code": "(async () => {\n  try {\n    const clipboardItems = await navigator.clipboard.read();\n\n    for (const item of clipboardItems) {\n      const imageType = item.types.find(type => type.startsWith('image/'));\n      \n      if (imageType) {\n        const blob = await item.getType(imageType);\n        const file = new File([blob], 'clipboard_image.jpg', { type: blob.type });\n        \n        // Load the file into a DataTransfer object\n        const dt = new DataTransfer();\n        dt.items.add(file);\n\n        // 1. Find Facebook's rich text box (they use role=\"textbox\")\n        const textBox = document.querySelector('[role=\"textbox\"]');\n        \n        if (textBox) {\n          // 2. Click/Focus the box so Facebook knows we are typing there\n          textBox.focus();\n\n          // 3. Create a fake \"Paste\" event that contains our image data\n          const pasteEvent = new ClipboardEvent('paste', {\n            clipboardData: dt,\n            bubbles: true,\n            cancelable: true\n          });\n\n          // 4. Fire the event directly at the text box\n          textBox.dispatchEvent(pasteEvent);\n          \n          console.log(\"✅ Image successfully pasted directly into the textbox!\");\n          return;\n        } else {\n          console.log(\"❌ Could not find Facebook's textbox.\");\n          return;\n        }\n      }\n    }\n    console.log(\"⚠️ No image found on the clipboard.\");\n  } catch (err) {\n    console.error(\"Clipboard access blocked or failed:\", err);\n  }\n})();", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": "1000"}, "label": "javascript-code", "blockId": "q5bpp62"}, {"id": "6ux2u0k", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1500.8914837876694, "y": 717.7019369441274}, "data": {"icon": "riSortAsc", "disableBlock": false, "description": "split image path", "valueSplit": "{{variables.imagepath}}", "delimiter": ",", "mode": "allValue", "indexPosition": 1, "assignVariable": true, "variableName": "loopimage", "isTrimWhitespaces": true, "delay": 0}, "label": "split-data"}, {"id": "k6vpd1l", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1760.82123661038, "y": 755.9623311354534}, "data": {"icon": "riRefreshLine", "disableBlock": false, "loopId": "multi_image", "maxLoop": 0, "toNumber": 10, "fromNumber": 1, "startIndex": 0, "loopData": "[]", "description": "multi_image", "variableName": "loopimage", "referenceKey": "", "reverseLoop": false, "elementSelector": "", "waitForSelector": false, "waitSelectorTimeout": 5000, "resumeLastWorkflow": false, "loopThrough": "variable", "delay": 0}, "label": "loop-data"}, {"id": "ihdnfp3", "type": "BlockLoopBreakpoint", "initialized": false, "position": {"x": 2899.5403877907625, "y": 904.4960543817122}, "data": {"icon": "riStopLine", "disableBlock": false, "loopId": "multi_image", "clearLoop": false}, "label": "loop-breakpoint"}, {"id": "o2zxbku", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1496.820476454178, "y": 790.4779148116028}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "แปลงลิงก์ google drive ให้เป็นลิงก์ที่สามารถคัดลอกได้", "timeout": "20000", "context": "website", "code": "// 1. รับค่าจาก Object ต้นทาง\nconst sourceData = RefData('variables', 'loopimage'); \n\n// 2. ใช้ Object.values() เพื่อดึงเอาเฉพาะ \"ค่าลิงก์\" ออกมาสร้างเป็น Array []\n// จากนั้นใช้ .map() เพื่อวนลูปเช็คลิงก์ทุกตัวใน Array นั้น\nconst updatedLoopImageArray = Object.values(sourceData).map(url => {\n  \n  // ตรวจสอบว่าเป็นลิงก์ Google Drive หรือไม่\n  if (url.includes('drive.google.com')) {\n    \n    // กรณีที่ 1: ลิงก์มาแบบ /file/d/ID/view (Standard Share Link)\n    if (url.includes('/d/')) {\n      return url.replace(/.*\\/d\\/([^/?]+).*/, \"https://drive.google.com/uc?export=download&id=$1\");\n    }\n    \n    // กรณีที่ 2: ลิงก์มาแบบมี id= อยู่แล้ว (Direct Link เดิม หรือรูปแบบอื่น)\n    if (url.includes('id=')) {\n      return url.replace(/.*id=([^&]+).*/, \"https://drive.google.com/uc?export=download&id=$1\");\n    }\n  }\n  \n  // ถ้าไม่ใช่ Google Drive ให้ส่งลิงก์เดิมกลับไป\n  return url;\n});\n\n// 3. บันทึกค่ากลับเป็น Array\nSetVariable('loopimage', updatedLoopImageArray);", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code", "blockId": "o2zxbku"}, {"id": "ug4exyj", "type": "BlockConditions", "initialized": false, "position": {"x": 1792.615209008794, "y": 555.8698573447573}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "rX2wx5LHpGiiWOW_SWVj2", "name": "Normal link", "conditions": [{"id": "T-iTg4e_7Jz6g7sdmueiH", "conditions": [{"id": "23XRjAZ0MksAOF9Esz21D", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.imagepath}}"}, "id": "wmZ2mq_wu6dpOcbSFeTbV"}, {"category": "compare", "type": "nct", "id": "i4hXvySz4wqy97tJzg9Kv"}, {"type": "value", "category": "value", "data": {"value": "drive"}, "id": "ACT6RbP-79yew6c1z7ZJX"}]}]}]}, {"id": "TaRmK7YOMlVL8eV1Yic7H", "name": "drive", "conditions": [{"id": "TQPeIT4czhBIxlnCYRS8z", "conditions": [{"id": "joWrw6ckEdFKlFEOuG0ZS", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.imagepath}}"}, "id": "OWW4rcwEwMLoxxFT-kgab"}, {"category": "compare", "type": "cnt", "id": "JlVEqY0RibVrjYWI963KL"}, {"type": "value", "category": "value", "data": {"value": "drive"}, "id": "-CsYYPp2IVctUV8uQnWzQ"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "hgh2eat", "type": "BlockConditions", "initialized": false, "position": {"x": 2004.3026651046507, "y": 785.5690347174831}, "data": {"icon": "riAB", "description": "", "disableBlock": false, "conditions": [{"id": "rX2wx5LHpGiiWOW_SWVj2", "name": "Normal link", "conditions": [{"id": "T-iTg4e_7Jz6g7sdmueiH", "conditions": [{"id": "23XRjAZ0MksAOF9Esz21D", "items": [{"type": "value", "category": "value", "data": {"value": "{{loopData.multi_image}}"}, "id": "wmZ2mq_wu6dpOcbSFeTbV"}, {"category": "compare", "type": "nct", "id": "i4hXvySz4wqy97tJzg9Kv"}, {"type": "value", "category": "value", "data": {"value": "drive"}, "id": "ACT6RbP-79yew6c1z7ZJX"}]}]}]}, {"id": "TaRmK7YOMlVL8eV1Yic7H", "name": "drive", "conditions": [{"id": "TQPeIT4czhBIxlnCYRS8z", "conditions": [{"id": "joWrw6ckEdFKlFEOuG0ZS", "items": [{"type": "value", "category": "value", "data": {"value": "{{loopData.multi_image}}"}, "id": "OWW4rcwEwMLoxxFT-kgab"}, {"category": "compare", "type": "cnt", "id": "JlVEqY0RibVrjYWI963KL"}, {"type": "value", "category": "value", "data": {"value": "drive"}, "id": "-CsYYPp2IVctUV8uQnWzQ"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions", "blockId": "hgh2eat"}, {"id": "nu0ctlc", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2338.6754785723324, "y": 848.9511878109315}, "data": {"icon": "riTerminalBoxLine", "command": "if (!(Test-Path 'C:\\tmp')) { New-Item -ItemType Directory -Path 'C:\\tmp' }; Invoke-WebRequest -Uri '{{variables.loopimage}}' -OutFile 'C:\\tmp\\image_{{profileId}}.jpg' -UseBasicParsing", "type": "powershell", "regex": "", "variableName": "", "assignVariable": false, "delay": 0, "description": "Windows"}, "label": "commandPro", "blockId": "nu0ctlc"}, {"id": "cgz420a", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2340.969236613621, "y": 925.3882511746475}, "data": {"icon": "riTerminalBoxLine", "command": "curl -L -k -A \"Mozilla/5.0\" \"{{loopData.multi_image}}\" -o /tmp/temp_fb.jpg && osascript -e 'set the clipboard to (read (POSIX file \"/tmp/temp_fb.jpg\") as JPEG picture)'", "type": "terminal", "regex": "", "variableName": "", "assignVariable": false, "delay": 0, "description": "MacOS"}, "label": "commandPro", "blockId": "cgz420a"}, {"id": "h1y2wzd", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2615.2746081828936, "y": 923.2435453402834}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "วางสำรอง", "timeout": "20000", "context": "website", "code": "(async () => {\n  try {\n    const clipboardItems = await navigator.clipboard.read();\n\n    for (const item of clipboardItems) {\n      const imageType = item.types.find(type => type.startsWith('image/'));\n      \n      if (imageType) {\n        const blob = await item.getType(imageType);\n        const file = new File([blob], 'clipboard_image.jpg', { type: blob.type });\n        \n        // Load the file into a DataTransfer object\n        const dt = new DataTransfer();\n        dt.items.add(file);\n\n        // 1. Find Facebook's rich text box (they use role=\"textbox\")\n        const textBox = document.querySelector('[role=\"textbox\"]');\n        \n        if (textBox) {\n          // 2. Click/Focus the box so Facebook knows we are typing there\n          textBox.focus();\n\n          // 3. Create a fake \"Paste\" event that contains our image data\n          const pasteEvent = new ClipboardEvent('paste', {\n            clipboardData: dt,\n            bubbles: true,\n            cancelable: true\n          });\n\n          // 4. Fire the event directly at the text box\n          textBox.dispatchEvent(pasteEvent);\n          \n          console.log(\"✅ Image successfully pasted directly into the textbox!\");\n          return;\n        } else {\n          console.log(\"❌ Could not find Facebook's textbox.\");\n          return;\n        }\n      }\n    }\n    console.log(\"⚠️ No image found on the clipboard.\");\n  } catch (err) {\n    console.error(\"Clipboard access blocked or failed:\", err);\n  }\n})();", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": "1000"}, "label": "javascript-code", "blockId": "h1y2wzd"}, {"id": "bis9hrq", "type": "BlockLoopBreakpoint", "initialized": false, "position": {"x": 1709.9343171771663, "y": 300.8739745602863}, "data": {"icon": "riStopLine", "disableBlock": false, "loopId": "loop_hashtag", "clearLoop": false}, "label": "loop-breakpoint"}, {"id": "tz8foan", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1460.2147738121098, "y": 218.83683970426137}, "data": {"icon": "riRefreshLine", "disableBlock": false, "loopId": "loop_hashtag", "maxLoop": 0, "toNumber": 10, "fromNumber": 1, "startIndex": 0, "loopData": "[]", "description": "", "variableName": "hashtag", "referenceKey": "", "reverseLoop": false, "elementSelector": "", "waitForSelector": false, "waitSelectorTimeout": 5000, "resumeLastWorkflow": false, "loopThrough": "variable", "delay": 0}, "label": "loop-data"}, {"id": "h2m7cn7", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1503.5506543280155, "y": 552.6677398875463}, "data": {"icon": "riSortAsc", "disableBlock": false, "description": "split image path", "valueSplit": "{{variables.imagepath}}", "delimiter": ",", "mode": "randomValue", "indexPosition": 1, "assignVariable": true, "variableName": "loopimage", "isTrimWhitespaces": true, "delay": 0}, "label": "split-data", "blockId": "h2m7cn7"}, {"id": "srtkw3w", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2391.780357071073, "y": 611.9441672414395}, "data": {"icon": "riTerminalBoxLine", "command": "if (!(Test-Path 'C:\\tmp')) { New-Item -ItemType Directory -Path 'C:\\tmp' }; Invoke-WebRequest -Uri '{{variables.loopimage}}' -OutFile 'C:\\tmp\\image_{{profileId}}.jpg' -UseBasicParsing", "type": "powershell", "regex": "", "variableName": "", "assignVariable": false, "delay": 0, "description": "Windows"}, "label": "commandPro", "blockId": "srtkw3w"}, {"id": "8ysv64r", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2656.950309174355, "y": 610.7398518768043}, "data": {"icon": "riFileUploadLine", "disableBlock": false, "findBy": "xpath", "waitForSelector": false, "waitSelectorTimeout": 5000, "selector": "(//div[(@aria-label=\"Photo/video\" or @aria-label=\"รูปภาพ/วิดีโอ\" or @aria-label=\"Ảnh/video\" or @aria-label=\"Foto/video\" or