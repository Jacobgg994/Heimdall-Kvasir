{"extVersion": 2, "name": "(Facebook) Update Profile and Cover Photo 1.1 (EN/TH/VN/ID/LO/RU/KO/JA/ZH)", "icon": "riUserSharedLine", "table": [], "version": "1.1.0", "drawflow": {"nodes": [{"id": "trigger-node", "type": "BlockBasic", "initialized": false, "position": {"x": -800, "y": 300}, "data": {"icon": "riPlayLine", "disableBlock": false, "description": "Start the update profile/cover workflow", "type": "manual", "interval": 60, "delay": 5, "date": "", "time": "00:00", "url": "", "shortcut": "", "activeInInput": false, "isUrlRegex": false, "days": [], "contextMenuName": "", "contextTypes": [], "parameters": [{"id": "p-profile-folder", "name": "profileImageFolderPath", "label": "Profile Image Folder Path", "type": "string", "description": "Folder path containing profile pictures. Will match profileName.jpg/png or pick random.", "defaultValue": "C:\\Users\\Admin\\Downloads\\🖼️ Images\\catImg", "placeholder": "e.g., C:\\Users\\Admin\\Downloads\\🖼️ Images\\catImg", "data": {"required": false}}, {"id": "p-cover-folder", "name": "coverImageFolderPath", "label": "Cover Image Folder Path", "type": "string", "description": "Folder path containing cover photos. Will match profileName.jpg/png or pick random.", "defaultValue": "C:\\Users\\Admin\\Downloads\\หน้าปก", "placeholder": "e.g., C:\\Users\\Admin\\Downloads\\หน้าปก", "data": {"required": false}}, {"id": "p-update-profile", "name": "updateProfile", "label": "Update Profile Picture?", "type": "checkbox", "description": "", "defaultValue": true, "placeholder": "Check to update profile picture", "data": {"required": false}}, {"id": "p-update-cover", "name": "updateCover", "label": "Update Cover Photo?", "type": "checkbox", "description": "", "defaultValue": true, "placeholder": "Check to update cover photo", "data": {"required": false}}], "preferParamsInTab": false, "observeElement": {"selector": "", "baseSelector": "", "matchPattern": "", "targetOptions": {"subtree": false, "childList": true, "attributes": false, "attributeFilter": [], "characterData": false}, "baseElOptions": {"subtree": false, "childList": true, "attributes": false, "attributeFilter": [], "characterData": false}}}, "label": "trigger"}, {"id": "get-profile-path-node", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": -550, "y": 300}, "data": {"icon": "riFileTextLine", "disableBlock": false, "description": "Get file paths from profile folder", "pathFolder": "{{variables.profileImageFolderPath}}", "isAddSubFolder": false, "fileType": "", "isFileType": false, "folderName": "", "assignVariable": true, "variableName": "Profile_pic", "delay": 0}, "label": "get-file-path"}, {"id": "get-cover-path-node", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": -300, "y": 300}, "data": {"icon": "riFileTextLine", "disableBlock": false, "description": "Get file paths from cover folder", "pathFolder": "{{variables.coverImageFolderPath}}", "isAddSubFolder": false, "fileType": "", "isFileType": false, "folderName": "", "assignVariable": true, "variableName": "Cover_pic", "delay": 0}, "label": "get-file-path"}, {"id": "js-selector-node", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": -50, "y": 300}, "data": {"icon": "riCodeSSlashLine", "disableBlock": false, "description": "Select images matching profileName or random", "timeout": "20000", "context": "background", "code": "// 1. Select Profile Picture\nconst profileFiles = RefData(\"variables\", \"Profile_pic\") || [];\nconst profileName = RefData(\"variables\", \"profileName\") || \"\";\nlet selectedProfile = \"\";\n\nfor (const file of profileFiles) {\n    const filename = file.split(/[\\\\/]/).pop().toLowerCase();\n    if (profileName && filename.includes(profileName.toLowerCase())) {\n        selectedProfile = file;\n        break;\n    }\n}\nif (!selectedProfile && profileFiles.length > 0) {\n    const randIndex = Math.floor(Math.random() * profileFiles.length);\n    selectedProfile = profileFiles[randIndex];\n}\nSetVariable(\"Selected_Profile_Pic\", selectedProfile);\nconsole.log(\"Selected Profile Pic: \" + selectedProfile);\n\n// 2. Select Cover Photo\nconst coverFiles = RefData(\"variables\", \"Cover_pic\") || [];\nlet selectedCover = \"\";\n\nfor (const file of coverFiles) {\n    const filename = file.split(/[\\\\/]/).pop().toLowerCase();\n    if (profileName && filename.includes(profileName.toLowerCase())) {\n        selectedCover = file;\n        break;\n    }\n}\nif (!selectedCover && coverFiles.length > 0) {\n    const randIndex = Math.floor(Math.random() * coverFiles.length);\n    selectedCover = coverFiles[randIndex];\n}\nSetVariable(\"Selected_Cover_Pic\", selectedCover);\nconsole.log(\"Selected Cover Pic: \" + selectedCover);", "preloadScripts": [], "everyNewTab": false, "runBeforeLoad": false, "delay": 0}, "label": "javascript-code"}, {"id": "open-url-node", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 200, "y": 300}, "data": {"icon": "riLink", "disableBlock": false, "url": "https://www.facebook.com/me", "userAgent": "", "description": "Open own profile page", "waitTabLoaded": false, "waitForNavigation": "domcontentloaded", "customUserAgent": false, "newTab": false, "active": true, "delay": 0}, "label": "open-url"}, {"id": "tab-loaded-node", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 450, "y": 300}, "data": {"icon": "riTimerFlashLine", "disableBlock": false, "delay": 0}, "label": "tab-loaded"}, {"id": "init-delay-node", "type": "BlockDelay", "initialized": false, "position": {"x": 700, "y": 300}, "data": {"icon": "riTimerLine", "disableBlock": false, "time": "5000"}, "label": "delay"}, {"id": "check-profile-cond", "type": "BlockConditions", "initialized": false, "position": {"x": 950, "y": 300}, "data": {"icon": "riAB", "description": "Check if user wants to update profile picture", "disableBlock": false, "conditions": [{"id": "cond-profile-yes", "name": "Update Profile", "conditions": [{"id": "group-profile-yes", "conditions": [{"id": "rule-profile-yes", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.updateProfile}}"}, "id": "val-prof-upd"}, {"category": "compare", "type": "eq", "id": "comp-prof-upd"}, {"type": "value", "category": "value", "data": {"value": "true"}, "id": "val-prof-true"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "click-profile-pic", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1250, "y": 150}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Click profile picture to edit", "x": "", "y": "", "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//div[@role=\"button\" and (@aria-label=\"Update profile picture\" or @aria-label=\"อัปเดตรูปโปรไฟล์\" or @aria-label=\"แก้ไขรูปโปรไฟล์\" or @aria-label=\"Cập nhật ảnh đại diện\" or @aria-label=\"Perbarui foto profil\" or @aria-label=\"ອັບເດດຮູບໂปຣໄຟລ໌\" or @aria-label=\"ແກ้ໄຂຮູບໂປຣໄຟລ໌\" or @aria-label=\"ແກ້ໄຂຮູບໂປຣໄຟລ໌\" or @aria-label=\"Обновить фото профиля\" or @aria-label=\"프로필 사진 업데이트\" or @aria-label=\"プロフィール写真を更新\" or @aria-label=\"更新个人资料照片\" or @aria-label=\"更新头像\" or @aria-label=\"更新大頭貼照\" or @aria-label=\"更新大头贴照\")]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": 2000, "humanClick": true}, "label": "event-click"}, {"id": "upload-profile-pic", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1500, "y": 150}, "data": {"icon": "riFolderUploadLine", "disableBlock": false, "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//span[text()=\"Upload photo\" or text()=\"อัปโหลดรูปภาพ\" or text()=\"อัปโหลดรูป\" or text()=\"Tải ảnh lên\" or text()=\"Unggah foto\" or text()=\"ອັບໂຫລດຮູບ\" or text()=\"ອັບໂຫຼດຮູບ\" or text()=\"Загрузить фото\" or text()=\"фото\" or text()=\"사진 업로드\" or text()=\"写真をアップロード\" or text()=\"上传照片\" or text()=\"上傳相片\" or text()=\"上傳照片\" or text()=\"Upload Photo\" or text()=\"Upload photo\" or text()=\"Select photo\" or text()=\"Choose photo\"]", "filePaths": ["{{variables.Selected_Profile_Pic}}"], "isFolderPath": false, "folderPath": "", "delay": 5000, "description": "Upload new profile picture file"}, "label": "upload-file"}, {"id": "save-profile-pic", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 1750, "y": 150}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Save new profile picture", "x": "", "y": "", "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//*[@role=\"button\" and (contains(., \"Save\") or contains(., \"บันทึก\") or contains(., \"Lưu\") or contains(., \"Simpan\") or contains(., \"บันທຶກ\") or contains(., \"Сохранить\") or contains(., \"저장\") or contains(., \"保存\") or contains(., \"儲存\") or contains(., \"储存\"))]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": 5000, "humanClick": true}, "label": "event-click"}, {"id": "check-cover-cond", "type": "BlockConditions", "initialized": false, "position": {"x": 2050, "y": 300}, "data": {"icon": "riAB", "description": "Check if user wants to update cover photo", "disableBlock": false, "conditions": [{"id": "cond-cover-yes", "name": "Update Cover", "conditions": [{"id": "group-cover-yes", "conditions": [{"id": "rule-cover-yes", "items": [{"type": "value", "category": "value", "data": {"value": "{{variables.updateCover}}"}, "id": "val-cov-upd"}, {"category": "compare", "type": "eq", "id": "comp-cov-upd"}, {"type": "value", "category": "value", "data": {"value": "true"}, "id": "val-cov-true"}]}]}]}], "retryConditions": false, "retryCount": 10, "retryTimeout": 1000, "delay": 0}, "label": "conditions"}, {"id": "click-edit-cover", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2350, "y": 150}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Click edit cover photo button", "x": "", "y": "", "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//div[@role=\"button\" and (contains(., \"Edit cover photo\") or contains(., \"แก้ไขรูปภาพหน้าปก\") or contains(., \"แก้ไขรูปหน้าปก\") or contains(., \"Chỉnh sửa ảnh bìa\") or contains(., \"Edit foto sampul\") or contains(., \"Редактировать обложку\") or contains(., \"カバー写真を編集\") or contains(., \"커버 사진 수정\") or contains(., \"编辑封面照片\") or contains(., \"編輯封面相片\") or contains(., \"ແກ้ໄຂຮູບໜ້າປົກ\"))]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": 2000, "humanClick": true}, "label": "event-click"}, {"id": "upload-cover", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2600, "y": 150}, "data": {"icon": "riFolderUploadLine", "disableBlock": false, "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//span[text()=\"Upload photo\" or text()=\"อัปโหลดรูปภาพ\" or text()=\"อัปโหลดรูป\" or text()=\"Tải ảnh lên\" or text()=\"Unggah foto\" or text()=\"ອັບໂຫລດຮູບ\" or text()=\"ອັບໂຫຼດຮູບ\" or text()=\"Загрузить фото\" or text()=\"фото\" or text()=\"사진 อัปโหลด\" or text()=\"写真をアップロード\" or text()=\"上传照片\" or text()=\"上傳相片\" or text()=\"上傳照片\"]", "filePaths": ["{{variables.Selected_Cover_Pic}}"], "isFolderPath": false, "folderPath": "", "delay": 5000, "description": "Upload new cover photo file"}, "label": "upload-file"}, {"id": "save-cover", "type": "BlockBasicWithFallback", "initialized": false, "position": {"x": 2850, "y": 150}, "data": {"icon": "riCursorLine", "disableBlock": false, "description": "Save cover photo changes", "x": "", "y": "", "findBy": "xpath", "waitForSelector": true, "waitSelectorTimeout": 15000, "selector": "//*[@role=\"button\" and (contains(., \"Save changes\") or contains(., \"บันทึกการเปลี่ยนแปลง\") or contains(., \"Lưu thay đổi\") or contains(., \"Simpan perubahan\") or contains(., \"บันທຶກการเปลี่ยนแปลง\") or contains(., \"Сохранить изменения\") or contains(., \"변경 내용 저장\") or contains(., \"변경사항 저장\") or contains(., \"변경 사항 저장\") or contains(., \"변경사항 저장\") or contains(., \"変更を保存\") or contains(., \"保存更改\") or contains(., \"儲存變更\"))]", "markEl": false, "multiple": false, "selectOption": "leftClick", "delay": 5000, "humanClick": true}, "label": "event-click"}, {"id": "end-node", "type": "BlockBasic", "initialized": false, "position": {"x": 3150, "y": 300}, "data": {"icon": "riFlagLine"}, "label": "end"}], "edges": [{"id": "edge-trig-getprof", "type": "bezier", "source": "trigger-node", "target": "get-profile-path-node", "sourceHandle": "trigger-node-output-1", "targetHandle": "get-profile-path-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-getprof-getcover", "type": "bezier", "source": "get-profile-path-node", "target": "get-cover-path-node", "sourceHandle": "get-profile-path-node-output-1", "targetHandle": "get-cover-path-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-getcover-js", "type": "bezier", "source": "get-cover-path-node", "target": "js-selector-node", "sourceHandle": "get-cover-path-node-output-1", "targetHandle": "js-selector-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-js-open", "type": "bezier", "source": "js-selector-node", "target": "open-url-node", "sourceHandle": "js-selector-node-output-1", "targetHandle": "open-url-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-open-load", "type": "bezier", "source": "open-url-node", "target": "tab-loaded-node", "sourceHandle": "open-url-node-output-1", "targetHandle": "tab-loaded-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-load-delay", "type": "bezier", "source": "tab-loaded-node", "target": "init-delay-node", "sourceHandle": "tab-loaded-node-output-1", "targetHandle": "init-delay-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-delay-condprof", "type": "bezier", "source": "init-delay-node", "target": "check-profile-cond", "sourceHandle": "init-delay-node-output-1", "targetHandle": "check-profile-cond-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-condprof-click", "type": "bezier", "source": "check-profile-cond", "target": "click-profile-pic", "sourceHandle": "check-profile-cond-output-cond-profile-yes", "targetHandle": "click-profile-pic-input-1", "updatable": true, "selectable": true, "data": {}, "label": "Yes", "markerEnd": "arrowclosed"}, {"id": "edge-click-upload", "type": "bezier", "source": "click-profile-pic", "target": "upload-profile-pic", "sourceHandle": "click-profile-pic-output-1", "targetHandle": "upload-profile-pic-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-upload-save", "type": "bezier", "source": "upload-profile-pic", "target": "save-profile-pic", "sourceHandle": "upload-profile-pic-output-1", "targetHandle": "save-profile-pic-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-save-condcover", "type": "bezier", "source": "save-profile-pic", "target": "check-cover-cond", "sourceHandle": "save-profile-pic-output-1", "targetHandle": "check-cover-cond-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-condprof-fallback", "type": "bezier", "source": "check-profile-cond", "target": "check-cover-cond", "sourceHandle": "check-profile-cond-output-fallback", "targetHandle": "check-cover-cond-input-1", "updatable": true, "selectable": true, "data": {}, "label": "Skip", "markerEnd": "arrowclosed"}, {"id": "edge-condcover-click", "type": "bezier", "source": "check-cover-cond", "target": "click-edit-cover", "sourceHandle": "check-cover-cond-output-cond-cover-yes", "targetHandle": "click-edit-cover-input-1", "updatable": true, "selectable": true, "data": {}, "label": "Yes", "markerEnd": "arrowclosed"}, {"id": "edge-clickcover-upload", "type": "bezier", "source": "click-edit-cover", "target": "upload-cover", "sourceHandle": "click-edit-cover-output-1", "targetHandle": "upload-cover-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-uploadcover-save", "type": "bezier", "source": "upload-cover", "target": "save-cover", "sourceHandle": "upload-cover-output-1", "targetHandle": "save-cover-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-savecover-end", "type": "bezier", "source": "save-cover", "target": "end-node", "sourceHandle": "save-cover-output-1", "targetHandle": "end-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "", "markerEnd": "arrowclosed"}, {"id": "edge-condcover-fallback", "type": "bezier", "source": "check-cover-cond", "target": "end-node", "sourceHandle": "check-cover-cond-output-fallback", "targetHandle": "end-node-input-1", "updatable": true, "selectable": true, "data": {}, "label": "Skip", "markerEnd": "arrowclosed"}], "position": [100, 100], "zoom": 0.8, "viewport": {"x": 100, "y": 100, "zoom": 0.8}}, "settings": {"publicId": "", "blockDelay": 0, "saveLog": true, "debugMode": false, "restartTimes": 3, "notification": true, "execContext": "popup", "reuseLastState": false, "inputAutocomplete": true, "onError": "stop-workflow", "executedBlockOnWeb": false, "insertDefaultColumn": false, "defaultColumnName": "column"}, "globalData": "", "description": "เวิร์กโฟลว์สำหรับเปลี่ยนรูปโปรไฟล์และรูปภาพหน้าปกเฟสบุ๊คโดยอัตโนมัติ รองรับ 9 ภาษา และสนับสนุนการรันหลายโปรไฟล์พร้อมกันโดยการอ่านจากโฟลเดอร์ภาพ โดย Antigravity", "trigger": {"icon": "riPlayLine", "disableBlock": false, "description": "Start the update profile/cover workflow", "type": "manual", "interval": 60, "delay": 5, "date": "", "time": "00:00", "url": "", "shortcut": "", "activeInInput": false, "isUrlRegex": false, "days": [], "contextMenuName": "", "contextTypes": [], "parameters": [{"id": "p-profile-folder", "name": "profileImageFolderPath", "label": "Profile Image Folder Path", "type": "string", "description": "Folder path containing profile pictures. Will match profileName.jpg/png or pick random.", "defaultValue": "C:\\Users\\Admin\\Downloads\\🖼️ Images\\catImg", "placeholder": "e.g., C:\\Users\\Admin\\Downloads\\🖼️ Images\\catImg", "data": {"required": false}}, {"id": "p-cover-folder", "name": "coverImageFolderPath", "label": "Cover Image Folder Path", "type": "string", "description": "Folder path containing cover photos. Will match profileName.jpg/png or pick random.", "defaultValue": "C:\\Users\\Admin\\Downloads\\หน้าปก", "placeholder": "e.g., C:\\Users\\Admin\\Downloads\\หน้าปก", "data": {"required": false}}, {"id": "p-update-profile", "name": "updateProfile", "label": "Update Profile Picture?", "type": "checkbox", "description": "", "defaultValue": true, "placeholder": "Check to update profile picture", "data": {"required": false}}, {"id": "p-update-cover", "name": "updateCover", "label": "Update Cover Photo?", "type": "checkbox", "description": "", "defaultValue": true, "placeholder": "Check to update cover photo", "data": {"required": false}}]}, "isProtected": false, "includedWorkflows": {}, "author": "Antigravity"}