{"extVersion": 2, "name": "[Demo] FB All-in-One 1.0", "icon": "riFacebookFill", "table": [], "version": "1.0.0", "drawflow": {"nodes": [{"id": "trg_master", "type": "BlockBasic", "label": "trigger", "initialized": false, "position": {"x": 0, "y": 0}, "data": {"icon": "riPlayLine", "disableBlock": false, "description": "", "type": "manual", "interval": 60, "delay": 5, "date": "", "time": "00:00", "url": "", "shortcut": "", "activeInInput": false, "isUrlRegex": false, "days": [], "contextMenuName": "", "contextTypes": [], "parameters": [{"id": "div_master", "name": "div_master", "label": "🎛️ เลือกฟังก์ชันที่ต้องการรัน", "type": "divider", "data": {"thickness": 1, "marginTop": 5, "marginBottom": 5, "label": "🎛️ เลือกฟังก์ชันที่ต้องการรัน"}}, {"id": "chk_m98yy", "name": "enableStatusCheck", "label": "✅ FB Status Check", "type": "checkbox", "description": "เปิดใช้งาน FB Status Check", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "chk_mr1wx", "name": "enableAutoPost", "label": "✅ FB Auto Post", "type": "checkbox", "description": "เปิดใช้งาน FB Auto Post", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "chk_m5caw", "name": "enableComment", "label": "✅ FB Comment", "type": "checkbox", "description": "เปิดใช้งาน FB Comment", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "chk_mmzys", "name": "enableShare", "label": "✅ FB Share", "type": "checkbox", "description": "เปิดใช้งาน FB Share", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "chk_m61gz", "name": "enableJoinGroup", "label": "✅ FB Join Group", "type": "checkbox", "description": "เปิดใช้งาน FB Join Group", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "chk_mazwz", "name": "enableWarmProfile", "label": "✅ FB Warm Profile", "type": "checkbox", "description": "เปิดใช้งาน FB Warm Profile", "defaultValue": true, "placeholder": "", "data": {"required": false}}, {"id": "di