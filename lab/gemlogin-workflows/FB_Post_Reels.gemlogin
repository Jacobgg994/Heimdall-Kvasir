      {
        "id": "48776w3",
        "type": "BlockBasicWithFallback",
        "label": "javascript-code",
        "initialized": false,
        "position": {
          "x": 378,
          "y": 250
        },
        "data": {
          "disableBlock": false,
          "description": "Validate input parameters",
          "icon": "riCodeBoxLine",
          "code": "// Validate inputs\nconst videoPath = '{{variables.reel_video_path}}';\nconst outputPath = '{{variables.output_link_path}}';\n\nlet valid = true;\nlet errors = [];\n\nif (!videoPath || videoPath.trim() === '') {\n    errors.push('Missing video file path');\n    valid = false;\n}\nif (!outputPath || outputPath.trim() === '') {\n    errors.push('Missing output link file path');\n    valid = false;\n}\n\nreturn {\n    valid: valid,\n    errors: errors.join('; ')\n};",
          "assignVariable": true,
          "variableName": "",
          "delay": 200,
          "timeout": 15000
        }
      },
