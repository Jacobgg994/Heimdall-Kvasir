          "description": "Extract latest Reel permalink",
          "icon": "riCodeBoxLine",
          "code": "// Find the newest Reel link — 3 strategies\nlet reelUrl = '';\n\n// 1: Are we on a Reel watch page?\nif (window.location.href.includes('/reel/') || window.location.href.includes('/reels/')) {\n    reelUrl = window.location.href;\n}\n\n// 2: Find first Reel link on the page\nif (!reelUrl) {\n    const links = document.querySelectorAll('a[href*=\"/reel/\"], a[href*=\"/reels/\"]');\n    for (const link of links) {\n        const href = link.getAttribute('href');\n        if (href && (href.includes('/reel/') || href.includes('/reels/'))) {\n            reelUrl = href.startsWith('http') ? href : 'https://www.facebook.com' + href.split('?')[0];\n            break;\n        }\n    }\n}\n\n// 3: Check embed/share inputs for permalink\nif (!reelUrl) {\n    const inputs = document.querySelectorAll('input[value*=\"permalink\"], input[value*=\"/reel/\"]');\n    for (const input of inputs) {\n        const val = input.value;\n        if (val && (val.includes('permalink') || val.includes('/reel/') || val.includes('/reels/'))) {\n            try { const url = new URL(val); reelUrl = url.searchParams.get('href') || val; }\n            catch(e) { reelUrl = val; }\n            break;\n        }\n    }\n}\n\nreturn { reel_url: reelUrl, found: reelUrl.length > 0 ? 'yes' : 'no', source_page: window.location.href };",
          "assignVariable": true,
          "variableName": "",
          "delay": 200,
          "timeout": 15000
        }
      },
