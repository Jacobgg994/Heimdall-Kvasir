          },
          "data": {
            "icon": "riCodeBoxLine",
            "disableBlock": false,
            "description": "Validate input parameters",
            "code": "// Validate inputs\nconst videoPath = '{{variables.reel_video_path}}';\nconst outputPath = '{{variables.output_link_path}}';\nconst usePage = '{{variables.use_page}}';\nconst pageUid = '{{variables.page_uid}}';\n\nlet valid = true;\nlet errors = [];\n\nif (!videoPath || videoPath.trim() === '') {\n    errors.push('Missing video file path');\n    valid = false;\n}\nif (!outputPath || outputPath.trim() === '') {\n    errors.push('Missing output link file path');\n    valid = false;\n}\nif (usePage === 'true' || usePage === true) {\n    if (!pageUid || pageUid.trim() === '') {\n        errors.push('Page UID required when posting as Page');\n        valid = false;\n    }\n}\n\nreturn {\n    valid: valid,\n    errors: errors.join('; '),\n    use_page: (usePage === 'true' || usePage === true) ? 'page' : 'profile'\n};",
            "assignVariable": true,
            "variableName": "",
            "delay": 200,
            "timeout": 15000
          },
          "events": {}
