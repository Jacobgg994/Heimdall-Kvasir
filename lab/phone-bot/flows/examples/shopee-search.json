{
  "name": "Shopee Product Search",
  "version": 2,
  "platform": "shopee",
  "orientation": "portrait",
  "resolution": "1080x1920",
  "randomization": {
    "coordinateJitter": 3,
    "delayVariation": 0.1
  },
  "steps": [
    {
      "action": "open_app",
      "package": "com.shopee.th",
      "desc": "Open Shopee TH"
    },
    {
      "action": "wait_for_element",
      "selector": {"resourceId": "com.shopee.th:id/search_bar"},
      "timeout": 15000,
      "desc": "Wait for Shopee to load"
    },
    {
      "action": "tap_element",
      "selector": {"resourceId": "com.shopee.th:id/search_bar"},
      "fallback": {"action": "tap", "x": 540, "y": 120},
      "desc": "Tap search bar"
    },
    {
      "action": "text",
      "value": "เสื้อผ้าผู้หญิง",
      "desc": "Type search query"
    },
    {
      "action": "keyevent",
      "code": 66,
      "desc": "Press Enter to search"
    },
    {
      "action": "wait",
      "ms": 3000,
      "msRandom": 1000,
      "desc": "Wait for search results"
    },
    {
      "action": "swipe",
      "x1": 540, "y1": 1500,
      "x2": 540, "y2": 500,
      "duration": 400,
      "repeat": {"min": 3, "max": 6},
      "repeatInterval": {"min": 1000, "max": 3000},
      "desc": "Scroll through results"
    }
  ],
  "createdAt": 1752249600000
}
